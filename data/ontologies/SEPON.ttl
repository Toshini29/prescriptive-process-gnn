:Surgical_Shock rdf:type owl:Class ;
                rdfs:subClassOf :Shock ;
                :Synonyms "Surgical Shock" ;
                :definition "Hypoperfusion of body tissues occurring during or after a surgical procedure, and resulting in cellular injury and vital organ dysfunction." ;
                :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C35019" ;
                rdfs:label "Surgical Shock" .


