                                                             :Synonyms """Rejuvenated Frozen Red Blood Cells
Red Blood Cells, Rejuvenated, Frozen
Red Blood Cells Rejuvenated Frozen""" ;
                                                             :definition "Red blood cells treated with a rejuvenating solution, then frozen and stored at ultra-low temperatures in the presence of a cryoprotective agent." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133353" ;
                                                             rdfs:label "Rejuvenated Frozen Red Blood Cells" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133354
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133354> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133280> ;
                                                             :Synonyms """Red Blood Cells Reconstituted
Red Blood Cells, Reconstituted
Reconstituted Red Blood Cells""" ;
                                                             :definition "Red blood cells to which plasma is added to prepare a whole blood product, often with a designated specific hematocrit." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133354" ;
                                                             rdfs:label "Reconstituted Red Blood Cells" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133355
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133355> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133280> ;
