:Lysozyme_Activity rdf:type owl:Class ;
                   rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ;
                   :Synonyms """mucopeptide N-acetylmuramoylhydrolase activity
muramidase activity
mucopeptide glucohydrolase activity
1,4-N-acetylmuramidase activity
N,O-diacetylmuramidase activity
lysozyme g
globulin G1
peptidoglycan N-acetylmuramoylhydrolase activity
PR1-lysozyme
globulin G
L-7001""" ;
                   :definition "Catalysis of the hydrolysis of the beta-(1->4) linkages between N-acetylmuramic acid and N-acetyl-D-glucosamine residues in a peptidoglycan." ;
                   :reference "http://purl.obolibrary.org/obo/GO_0003796" ;
                   rdfs:label "Lysozyme Activity" .


