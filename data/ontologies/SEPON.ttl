###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13724
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13724> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13299> ;
                                                            :Synonyms "Central DNA Flap Sequence" ;
                                                            :definition "In Lentivirus, a central strand displacement event consecutive to central initiation and termination of plus strand synthesis creates a plus strand overlap: the central DNA flap. This feature promotes efficient nuclear import and viral replication in non-dividing cells." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13724" ;
                                                            rdfs:label "Central DNA Flap Sequence" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13725
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13725> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13404> ;
                                                            :Synonyms """G-Quadruplex
G-Quadruplexes
G-Quartet Structures
G-Quadruplexes DNA
G-Quartets
G-Tetrads
G4-DNA""" ;
                                                            :definition "G-quadruplexes are multi-stranded structures held together by square planes of four guanines ('G-quartets') interacting by forming Hoogsteen hydrogen bonds. G-quartet structures has been developed as novel anti-HIV agents. Several critical structure-activity relationships between HIV-1 integrase and G-quartet oligonucleotides have been demonstrated." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13725" ;
                                                            rdfs:label "G-Quartets" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13742
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13742> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13404> ;
                                                            :Synonyms "Minor Groove" ;
                                                            :definition "The smaller of the two types of spiral grooves found on a right-handed DNA double helix; located between the sugar phosphate backbones of two DNA strands." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13742" ;
                                                            rdfs:label "Minor Groove" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13743
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13743> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13404> ;
                                                            :Synonyms "Major Groove" ;
                                                            :definition "One of the two types of grooves found in a right-handed double helix, running between the sugar phosphate backbones of each strand." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13743" ;
                                                            rdfs:label "Major Groove" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13804
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13804> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13298> ;
                                                            :Synonyms """Short Interspersed Nuclear Element
Short Interspersed Element
SINE
SINES""" ;
                                                            :definition "SINEs. Short, 100-300 bases long, highly repeated sequences which contain RNA polymerase III promoters. The primate Alu and the rodent B1 SINEs are derived from 7SL RNA, the RNA component of the signal recognition particle. Most other SINEs are derived from tRNAs including the MIRs (mammalian-wide interspersed repeats)." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13804" ;
                                                            rdfs:label "Short Interspersed Element" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C139562
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C139562> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12664> ;
                                                             :Synonyms "Upper Abdomen" ;
