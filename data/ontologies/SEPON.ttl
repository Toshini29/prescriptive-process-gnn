:Phosphotransferase rdf:type owl:Class ;
                    rdfs:subClassOf :Transferase ;
                    :Synonyms """Phosphotransferase
Phosphotransferases
EC 2.7""" ;
                    :definition "A class of enzymes that transfer phosphate or phosphate-containing molecules to organic substrates. These proteins play a role in the regulation of many cellular processes." ;
