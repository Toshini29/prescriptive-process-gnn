###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Low_Grade_Fever
:Low_Grade_Fever rdf:type owl:Class ;
                 rdfs:subClassOf :Fever ;
                 :Synonyms "Low Grade Fever" ;
                 :definition "Body temperature ranging between 100.4 degrees Fahrenheit (38 degrees Celsius) and 102 degrees Fahrenheit (38.9 degrees Celsius)." ;
                 :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C35292" ;
                 rdfs:label "Low Grade Fever" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Low_Molecular_Weight_Heparin
:Low_Molecular_Weight_Heparin rdf:type owl:Class ;
                              rdfs:subClassOf :Anticoagulant_Agent ;
                              :Synonyms """Low Molecular Weight Heparin
Low-molecular-weight heparin
LMWH""" ;
                              :definition "Substances comprised of fragmented heparin molecules derived from unfractionated heparin that bind to antithrombin III with a molecular weight ranging from 1000 to 10,000 daltons, which causes changes in property from unfractionated heparin, including decreased protein binding, enhanced bioavailability, decreased platelet interaction, and decreased binding to thrombin." ;
                              :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C2578" ;
                              rdfs:label "Low Molecular Weight Heparin" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Lung_Interstitial_Tissue
:Lung_Interstitial_Tissue rdf:type owl:Class ;
                          rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33024> ;
                          :Synonyms """Lung Interstitium
Lung Interstitial Tissue""" ;
                          :definition "Lung tissue consisting of alveolar cells, pulmonary capillary endothelium, basement membrane, and perivascular tissues." ;
                          :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C190108" ;
                          rdfs:label "Lung Interstitial Tissue" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Lyase
:Lyase rdf:type owl:Class ;
       rdfs:subClassOf :Enzyme ;
       :Synonyms """EC 4
Lyase""" ;
       :definition "Trivial name applied, together with dehydratase, to certain hydro-lyases (EC class 4.2.1) catalyzing hydration-dehydration." ;
       :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16804" ;
       rdfs:label "Lyase" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Lyase_Gene
:Lyase_Gene rdf:type owl:Class ;
            rdfs:subClassOf :Enzyme_Gene ;
            :Synonyms "Lyase Gene" ;
            :definition "Lyase Genes encode Lyases, a class of enzymes that catalyze the hydration-dehydration cleavage of C-C, C-O, C-N, and other bonds by means other than hydrolysis or oxidation." ;
            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C21282" ;
            rdfs:label "Lyase Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Lymph_Node_Cortex
:Lymph_Node_Cortex rdf:type owl:Class ;
                   rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13049> ;
                   :Synonyms "Lymph Node Cortex" ;
                   :definition "The portion of the lymph node that contains nodules with germinal centers where B lymphocyte mature into plasma cells after activation. The nodules are separated by diffuse lymphatic tissue, lymph sinuses and trabeculae." ;
                   :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33029" ;
                   rdfs:label "Lymph Node Cortex" .


