                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12404" ;
                                                            rdfs:label "Ovary" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12405
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12405> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Uterus, NOS
Genital System, Female, Uterus
Uterine structure (body structure)
UTERUS
Uterine
Utero
Uterus
Womb
uterus
womb""" ;
                                                            :definition "A hollow, thick-walled, muscular organ located within the pelvic cavity of a woman. Within the uterus the fertilized egg implants and the fetus develops during pregnancy." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12405" ;
                                                            rdfs:label "Uterus" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12406
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12406> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12405> ;
