###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#S100_Calcium_Binding_Protein
:S100_Calcium_Binding_Protein rdf:type owl:Class ;
                              rdfs:subClassOf :Ligand_Binding_Protein ;
                              :Synonyms """S100 Calcium Binding Protein
S100 Protein
S-100 Protein
S100""" ;
                              :definition "A family of low molecular weight proteins that are characterized by the presence of two EF-hand calcium binding domains. These proteins form homodimers that localize either in the cytoplasm or nucleus of neural crest-derived cells and are involved in the regulation of many cellular processes such as cell cycle progression and differentiation." ;
                              :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C29924" ;
                              rdfs:label "S100 Calcium Binding Protein" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#S100_Family_Gene
:S100_Family_Gene rdf:type owl:Class ;
                  rdfs:subClassOf :Ligand_Binding_Protein_Gene ;
                  :Synonyms "S100 Family Gene" ;
                  :definition "S100 Family Gene members, many clustered on chromosome 1q21, encode S100 Calcium Binding Proteins localized in the cytoplasm and/or nucleus of many cells that often regulate cellular processes such as cell cycle progression and differentiation." ;
                  :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20849" ;
                  rdfs:label "S100 Family Gene" .


