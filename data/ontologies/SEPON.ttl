                           rdfs:subClassOf :Anticoagulant_Agent ;
                           :Synonyms """Direct Thrombin Inhibitor
DTI""" ;
                           :definition "Any agent that directly binds to and inactivates thrombin (factor IIa), with anticoagulant activity." ;
                           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C173066" ;
                           rdfs:label "Direct Thrombin Inhibitor" .


