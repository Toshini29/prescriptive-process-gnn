###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Erythrocyte_Distribution_Width_Measurement
:Erythrocyte_Distribution_Width_Measurement rdf:type owl:Class ;
                                            rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ,
                                                            :Hematology_Test ,
                                                            :Neonatal_Sepsis_Biomarker ;
                                            :Synonyms """Erythrocyte Distribution Width Measurement
Erythrocytes Distribution Width
Red Blood Cell Distribution Width
Red Cell Volume Distribution Width
RDW
RDW-CV""" ;
                                            :definition "An index of the variation in the size of the red cells and can be used to detect subtle degress of anisocytosis. It is computed directly from the RBC histogram and is calculated as a standard statictical value, the coefficient of variation of the red cell volume ditribution (ratio of standard deviation and mean copuscular volume)." ;
                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C64800" ;
                                            rdfs:label "Erythrocyte Distribution Width Measurement" .


