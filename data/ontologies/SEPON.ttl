                                     rdfs:subClassOf :Sign_or_Symptom ;
                                     :Synonyms "Endocrine System Signs and Symptoms" ;
                                     :definition "Patient complaints, physical findings, laboratory findings referable to the endocrinologic system." ;
                                     :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C5033" ;
                                     rdfs:label "Endocrine System Signs and Symptoms" .


