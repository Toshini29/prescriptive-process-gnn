                                                            :Synonyms "Hepatic Lobule" ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32732" ;
                                                            rdfs:label "Hepatic Lobule" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32733
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32733> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32735> ;
                                                            :Synonyms "Hepatic Sinusoid" ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32733" ;
                                                            rdfs:label "Hepatic Sinusoid" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32735
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32735> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C43614> ;
                                                            :Synonyms """Liver Tissue
Hepatic Tissue
Hepatic Parenchyma""" ;
                                                            :definition "The tissue of the liver. It includes the hepatic lobules, hepatic sinusoids, perisinusoidal spaces, and portal triad. The hepatic lobules are composed of hepatocytes." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32735" ;
                                                            rdfs:label "Hepatic Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32787
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32787> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12765> ;
                                                            :Synonyms "Inferior Parathyroid Gland" ;
                                                            :definition "Either of two paired parathyroid glands distal to the head." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32787" ;
                                                            rdfs:label "Inferior Parathyroid Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32820
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32820> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Intercalated Duct" ;
                                                            :definition "One of two types of intercalated ducts located in either the pancreas or salivary gland." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32820" ;
                                                            rdfs:label "Intercalated Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32828
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32828> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Interlobular Duct" ;
                                                            :definition "A gland duct that drains secretions from more than one lobe of an organ." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32828" ;
                                                            rdfs:label "Interlobular Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32875
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32875> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13321> ;
                                                            :Synonyms "Intestinal Secretion" ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32875" ;
                                                            rdfs:label "Intestinal Secretion" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32891
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32891> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33461> ;
                                                            :Synonyms "Juxtaglomerular Apparatus" ;
                                                            :definition "Cellular population adjacent to the renal corpuscle, composed of the macula densa, the juxtaglomerular cells, and the extraglomerular mesangial cells. It regulates the blood pressure by activating the renin-angiotensin-aldosterone system." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32891" ;
                                                            rdfs:label "Juxtaglomerular Apparatus" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32910
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32910> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Lactiferous Duct" ;
                                                            :definition "A channel conveying the milk secreted by the lobes of the breast to and through the nipple." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32910" ;
                                                            rdfs:label "Lactiferous Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32926
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32926> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32931> ;
                                                            :Synonyms "Large Intestinal Mucosa" ;
                                                            :definition "Mucosa consisting of the epithelium, basement membrane, lamina propria mucosae and lamina muscularis mucosae of the distal portion of the digestive tract from the small intestine to the anus." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32926" ;
                                                            rdfs:label "Large Intestinal Mucosa" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32927
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32927> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32931> ;
                                                            :Synonyms "Large Intestinal Muscular Coat" ;
                                                            :definition "The portion of the intestinal covering that contracts causing peristalsis. It surrounds the weblike submucosa of the distal portion of the digestive tract from the small intestine to the anus." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32927" ;
                                                            rdfs:label "Large Intestinal Muscular Coat" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32929
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32929> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32931> ;
                                                            :Synonyms "Large Intestinal Serosal Surface" ;
                                                            :definition "The membrane lining the external walls of the distal portion of the digestive tract from the small intestine to the anus. It consists of mesothelium on a connective tissue layer and it secretes a watery exudate." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32929" ;
                                                            rdfs:label "Large Intestinal Serosal Surface" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32931
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32931> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C49478> ;
                                                            :Synonyms "Large Intestinal Wall Tissue" ;
                                                            :definition "The tissue of the large intestine. It is composed of four layers - mucosa, submucosa, smooth muscle with inner circular and outer longitudinal layers, and serosa. The mucosa has a large number of goblet cells but does not have any villi. The longitudinal muscle layer is incomplete. The longitudinal muscle is limited to three distinct bands, called teniae coli that run the entire length of the colon. Contraction of the teniae coli exerts pressure on the wall and creates a series of pouches, called haustra, along the colon. Epiploic appendages, pieces of fat-filled connective tissue, are attached to the outer surface of the colon." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32931" ;
                                                            rdfs:label "Large Intestinal Wall Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32959
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32959> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12403> ;
                                                            :Synonyms """Fallopian Tube, Left
Left Fallopian Tube""" ;
                                                            :definition "The fallopian tube that extends from the uterus to the ovary in the left side of the pelvic cavity." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32959" ;
                                                            rdfs:label "Left Fallopian Tube" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32967
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32967> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12468> ;
                                                            :Synonyms """LUNG, LEFT
Left Lung""" ;
                                                            :definition "The 2-lobed lung located on the left side of the body." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32967" ;
                                                            rdfs:label "Left Lung" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32969
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32969> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12404> ;
                                                            :Synonyms """Ovary, Left
Left Ovary""" ;
                                                            :definition "The ovary that is located in the left side of the pelvis." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32969" ;
                                                            rdfs:label "Left Ovary" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32988
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32988> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12802> ;
                                                            :Synonyms """Lingual tonsil
Lingual Tonsil
TONSIL, LINGUAL""" ;
                                                            :definition "The lymphoid follicles on the dorsal surface in the posterior region of the tongue." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32988" ;
                                                            rdfs:label "Lingual Tonsil" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33024
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33024> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12801> ;
                                                            :Synonyms """Lung Parenchyma
Lung Tissue""" ;
                                                            :definition "Tissue consisting of an external serous coat, subserous areolar tissue and lung parenchyma. The parenchyma is made up of lobules wound together by connective tissue. A primary lobule consists of a terminal bronchiole, respiratory bronchioles, and alveolar ducts, which communicate with many alveoli, each alveolus being surrounded by a network of capillary blood vessels." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33024" ;
                                                            rdfs:label "Lung Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33040
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33040> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13049> ;
                                                            :Synonyms "Lymphoid Follicle" ;
                                                            :definition "Nodular structures composed of lymphocytes. In the absence of immune stimulation, they ae called primary follicles and are composed of small B-lymphocytes. With antigenic stimulation the B-lymphocytes replicate and differentiate, to give rise to secondary follicles which are composed of germinal centers and are surrounded by mantle zones." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33040" ;
                                                            rdfs:label "Lymphoid Follicle" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33050
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33050> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12417> ;
                                                            :Synonyms "Male Urethra" ;
                                                            :definition "The 8 inch long tube carrying urine from the bladder to the outside of the body exiting at the end of the penis." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33050" ;
                                                            rdfs:label "Male Urethra" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33053
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33053> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13049> ;
                                                            :Synonyms "Mantle Zone" ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33053" ;
                                                            rdfs:label "Mantle Zone" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33101
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33101> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33461> ;
                                                            :Synonyms "Mesangium" ;
                                                            :definition "A thin membrane in the central part of the renal glomerulus between capillaries. It helps to support the capillary loops in the glomerulus. Mesangial cells are phagocytic and for the most part separated from capillary lumina by endothelial cells." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33101" ;
                                                            rdfs:label "Mesangium" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33161
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33161> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms """Nasolacrimal Duct
DUCT, NASOLACRIMAL""" ;
                                                            :definition "A tube-like structure that conveys tears from the lacrimal sac to the nasal cavity." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33161" ;
                                                            rdfs:label "Nasolacrimal Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33224
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33224> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Organ of Special Sense
Special Sense Organ""" ;
                                                            :definition "Anatomic structures in the head responsible for special sensations rather than general sensations. This category includes the eyes, ears, nose, and tongue." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33224" ;
                                                            rdfs:label "Organ of Special Sense" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33231
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33231> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13236> ;
                                                            :Synonyms "Otolymph" ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33231" ;
                                                            rdfs:label "Otolymph" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33250
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33250> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12802> ;
                                                            :Synonyms """Palatine Tonsil
TONSIL, PALATINE""" ;
                                                            :definition "Two masses of lymphatic tissue located one on either side of the oropharynx in the oropharyngeal isthmus." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33250" ;
                                                            rdfs:label "Palatine Tonsil" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33255
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33255> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13270> ;
                                                            :Synonyms """Endocrine Pancreas Secretion
Pancreatic Endocrine Secretion""" ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33255" ;
                                                            rdfs:label "Pancreatic Endocrine Secretion" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33256
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33256> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13270> ;
                                                            :Synonyms """Pancreatic Juices
Pancreatic Exocrine Secretion
pancreatic juice
Exocrine Pancreas Secretion
Pancreatic Fluid
Pancreatic fluid""" ;
                                                            :definition "Secretion from the pancreas that contains digestive enzymes." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33256" ;
                                                            rdfs:label "Pancreatic Exocrine Secretion" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33270
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33270> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12801> ;
                                                            :Synonyms """Human Parathyroid
Parathyroid Gland Tissue""" ;
                                                            :definition "Parathyroid gland tissue consists of three primary cell types - chief cells, oxyphil cells and clear cells. These glands are usually located in close proximity to the thyroid gland." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33270" ;
                                                            rdfs:label "Parathyroid Gland Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33277
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33277> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms """Stensen's Duct
Parotid Duct""" ;
                                                            :definition "A small, tubular passageway carrying saliva from the parotid gland to the oropharynx." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33277" ;
                                                            rdfs:label "Parotid Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33294
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33294> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13049> ,
                                                                            <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C34086> ;
                                                            :Synonyms """T-Cell Zone of the Spleen
T-Cell Zone of Spleen
Periarteriolar Lymphoid Sheath""" ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33294" ;
                                                            rdfs:label "Periarteriolar Lymphoid Sheath" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33297
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33297> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33231> ;
                                                            :Synonyms "Perilymph" ;
                                                            :definition "The bodily fluid that fills the space between the bony labyrinth and the membranous labyrinth of the inner ear." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33297" ;
                                                            rdfs:label "Perilymph" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33308
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33308> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33414> ;
                                                            :Synonyms """Peripheral Zone of the Prostatic Parenchyma
PZ""" ;
                                                            :definition "Prostatic parenchyma that occupies the posterior and lateral aspects of the prostate gland. The glandular architecture consists of small, round acini amid loosely woven, randomly oriented stroma. The peripheral zone contains large, so-called main glands, whose ducts run posteriorly to open into the urethra. Approximately 70% of the prostate gland lies in the peripheral zone." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33308" ;
                                                            rdfs:label "Peripheral Zone of the Prostatic Parenchyma" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33309
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33309> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32735> ;
                                                            :Synonyms """Perisinusoidal Space
Space of Disse""" ;
                                                            :definition "The area between hepatocytes and the epithelium lining the sinusoids of the liver. The space contains reticular fibers and microvilli from the hepatocytes. Proteins produced by the hepatocytes are transferred to the blood via the perisinusoidal space as blood fluids easily move through the epithelium and microvilli." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33309" ;
                                                            rdfs:label "Perisinusoidal Space" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33311
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33311> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33414> ;
                                                            :Synonyms "Periurethral Zone of the Prostatic Parenchyma" ;
                                                            :definition "The inner most portion of the prostatic parenchyma surrounding the mid and proximal portions of the prostatic urethra where the ejaculatory ducts enter the urethra." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33311" ;
                                                            rdfs:label "Periurethral Zone of the Prostatic Parenchyma" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33318
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33318> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12802> ;
                                                            :Synonyms """nasopharyngeal tonsil
tonsilla pharyngealis
tonsil of Luschka
pharyngeal tonsil
TONSIL, PHARYNGEAL
PHARYNGEAL TONSIL
Pharyngeal Tonsil
Tonsil (Pharyngeal)
Adenoid
adenoid""" ;
                                                            :definition "A fold of lymphatic tissue covered by ciliated epithelium at the very back of the nose, in the roof of the nasopharynx." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33318" ;
                                                            rdfs:label "Pharyngeal Tonsil" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33342
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33342> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32735> ;
                                                            :Synonyms "Portal Triad" ;
                                                            :definition "An anatomical unit of hepatic tissue, composed of an interlobular vein of liver, an interlobular artery of liver and an interlobular bile duct. The triads are embedded in the interlobular connective tissue and travel together throughout the liver parenchyma." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33342" ;
                                                            rdfs:label "Portal Triad" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33407
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33407> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33414> ;
                                                            :Synonyms "Prostatic Duct Tissue" ;
                                                            :definition "Simple columnar epithelial tissue of the small canals that transport prostatic secretions from the glandular tubules to the urethra." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33407" ;
                                                            rdfs:label "Prostatic Duct Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33414
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33414> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12801> ;
                                                            :Synonyms """Prostatic Tissue
Prostatic Parenchyma""" ;
                                                            :definition "Tissue composed of tubuloalveolar glands embedded in fibromuscular stroma. The stroma is smooth muscle separated by strands of connective tissue rich in collagenous and elastic fibers. The secretory alveoli of the prostate are irregularly shaped with papillary projections of the mucosa into the lumen of the gland." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33414" ;
                                                            rdfs:label "Prostatic Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33428
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33428> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33024> ;
                                                            :Synonyms "Pulmonary Lobule" ;
                                                            :definition "The smallest anatomical unit of the lung, measuring 0.50 to 2.00 cm in diameter. Each lobule is composed of 4-8 terminal bronchioles and their distal alveolar ducts and sacs. The lobules are separated by fibrous interlobular septa." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33428" ;
                                                            rdfs:label "Pulmonary Lobule" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33431
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33431> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712> ;
                                                            :Synonyms "Pyloric Gland" ;
                                                            :definition "The coiled tubular glands that produce mucous and gastrin located around the pylorus in the stomach." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33431" ;
                                                            rdfs:label "Pyloric Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33461
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33461> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12801> ;
                                                            :Synonyms "Renal Tissue" ;
                                                            :definition "Tissue composed of the renal cortex and the renal medulla. The basic functional unit of renal tissue is the nephron." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33461" ;
                                                            rdfs:label "Renal Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33475
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33475> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12403> ;
                                                            :Synonyms """Fallopian Tube, Right
Right Fallopian Tube""" ;
                                                            :definition "The fallopian tube that extends from the uterus to the ovary in the right side of the pelvic cavity." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33475" ;
                                                            rdfs:label "Right Fallopian Tube" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33483
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33483> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12468> ;
                                                            :Synonyms """LUNG, RIGHT
Right Lung""" ;
                                                            :definition "The 3-lobed lung located on the right side of the body." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33483" ;
                                                            rdfs:label "Right Lung" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33484
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33484> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Right Lymphatic Duct" ;
                                                            :definition "A lymphatic vessel that drains lymph from the right side of the head and neck, the right arm, and the right thoracic cavity." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33484" ;
                                                            rdfs:label "Right Lymphatic Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33487
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33487> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12404> ;
                                                            :Synonyms """Right Ovary
Ovary, Right""" ;
                                                            :definition "The ovary that is located in the right side of the pelvis." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33487" ;
                                                            rdfs:label "Right Ovary" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33509
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33509> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12801> ;
                                                            :Synonyms "Salivary Gland Tissue" ;
                                                            :definition "Tissue consisting of mucous or serous secreting epithelial tissue, connective tissue, blood vessels, nerves and lymphatic tissue." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33509" ;
                                                            rdfs:label "Salivary Gland Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33519
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33519> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712> ;
                                                            :Synonyms """SEBACEOUS GLAND
GLAND, SEBACEOUS
Sebaceous Gland""" ;
                                                            :definition "Small glands located within the epidermis, and associated with the hair follicle, that produce and secrete an oily substance that lubricates the skin and hair." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33519" ;
                                                            rdfs:label "Sebaceous Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33520
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33520> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Sebaceous Gland Duct" ;
                                                            :definition "The small tube that carries sebum from the sebaceous gland to the hair follicle or skin." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33520" ;
                                                            rdfs:label "Sebaceous Gland Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33528
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33528> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Semicircular Duct" ;
                                                            :definition "The membranous tube that is located within the osseous semicircular canal." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33528" ;
                                                            rdfs:label "Semicircular Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33529
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33529> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C52552> ;
                                                            :Synonyms """Seminal fluid
Seminal Fluid
SEMINAL FLUID
seminal fluid""" ;
                                                            :definition "Part of the ejaculated fluid. It contains secretions from the seminal vesicles, Cowper's gland, and prostate gland." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33529" ;
                                                            rdfs:label "Seminal Fluid" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33568
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33568> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33573> ;
                                                            :Synonyms """Small Bowel Mucosa
organ mucosa of small bowel
small intestine mucosa of organ
mucosa of organ of small intestine
small bowel mucosa
Small Intestinal Mucosa
tunica mucosa intestini tenuis
small intestine mucous membrane
mucosa of small bowel
small bowel mucosa of organ
SMALL INTESTINAL MUCOSA
tunica mucosa (intestinum tenue)
small intestinal mucosa
small intestine mucosa
mucous membrane of small bowel
mucosa of small intestine
mucosa of organ of small bowel
small bowel organ mucosa
small bowel mucous membrane
mucous membrane of small intestine
small intestine organ mucosa
organ mucosa of small intestine""" ;
                                                            :definition "Mucosa arranged into two fundamental structures - villi and crypts of Lieberkuhn. Villi are projections into the lumen of the small intestine, covered with simple columnar epithelium. Crypts of Lieberkuhn are moat-like invaginations of the epithelium around the villi that extend through the lamina propria down to the muscularis mucosae. Lymphocytes often invade the epithelium or form solitary lymphoid nodules in the lamina propria. Lymph nodules may form longitudinal aggregations of 30-50 nodules in the lamina propria of the ileum. These large aggregations are called Peyer's patches. The muscularis mucosae has two layers and extends into the intestinal villi, where the smooth muscle cells form a longitudinal bundle in the centre of the villi. The small intestinal mucosa secretes gastrin, somatostatin, cholecystokinin and secretin." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33568" ;
                                                            rdfs:label "Small Intestinal Mucosa" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33569
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33569> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33573> ;
                                                            :Synonyms "Small Intestinal Muscular Coat" ;
                                                            :definition "Muscular coat consisting of two layers of smooth muscle - an external, longitudinal, and an internal, circular layer. The longitudinal fibers are thinly scattered over the surface of the small intestine, and are more distinct along its free border. The circular fibers form a thick, uniform layer, and are composed of plain muscle cells of considerable length. The muscular coat is thicker at the upper than at the lower part of the small intestine. Interstitial cells of Cajal are present in the small intestinal muscular coat." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33569" ;
                                                            rdfs:label "Small Intestinal Muscular Coat" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33571
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33571> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33573> ;
                                                            :Synonyms "Small Intestinal Serosal Surface" ;
                                                            :definition "The thin outermost layer of loose connective tissue covering the outer surface of the small intestine. It is derived from the peritoneum." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33571" ;
                                                            rdfs:label "Small Intestinal Serosal Surface" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33573
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33573> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C49478> ;
                                                            :Synonyms "Small Intestinal Wall Tissue" ;
                                                            :definition "The tissue of the small intestine. It comprises four layers - mucosa with simple columnar epithelium, submucosa, smooth muscle with inner circular and outer longitudinal layers, and serosa." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33573" ;
                                                            rdfs:label "Small Intestinal Wall Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33574
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33574> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C34062> ;
                                                            :Synonyms """SMEGMA
Smegma""" ;
                                                            :definition "A white secretion of the sebaceous glands of the foreskin." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33574" ;
                                                            rdfs:label "Smegma" .


