           rdfs:subClassOf :Neurological_Signs_and_Symptoms ;
           :Synonyms """Lightheadedness
Dizziness
Dizzy""" ;
           :definition "A sensation of lightheadedness, unsteadiness, turning, spinning or rocking." ;
           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C37943" ;
           rdfs:label "Dizziness" .


