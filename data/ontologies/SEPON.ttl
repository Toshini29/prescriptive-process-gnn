###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Interleukin_Gene
:Interleukin_Gene rdf:type owl:Class ;
                  rdfs:subClassOf :Cytokine_Gene ;
                  :Synonyms "Interleukin Gene" ;
                  :definition "Interleukin Genes encode Interleukins, soluble cytokine factors produced by leukocytes and other cell types that have broad functional activities, particularly in regulating the inflammatory and immune responses of a variety of cell types. Interleukins enhance cell proliferation and differentiation, DNA synthesis, secretion of other biologically active molecules, and responses to immune and inflammatory stimuli." ;
                  :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C25982" ;
                  rdfs:label "Interleukin Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Intermediate_Filament_Gene
:Intermediate_Filament_Gene rdf:type owl:Class ;
                            rdfs:subClassOf :Cytoskeletal_Gene ;
                            :Synonyms "Intermediate Filament Gene" ;
                            :definition "Intermediate Filament Genes encode a number of different Intermediate Filament Proteins (including keratin filaments, neurofilaments, desmin, and vimentin) that form polymeric structural cytoplasmic filaments, intermediate in diameter (8-10 nanometer) between actin microfilaments and microtubules, which comprise part of the cytoskeleton of most eukaryotic cells." ;
                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C30073" ;
                            rdfs:label "Intermediate Filament Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Intermediate_Filament_Protein
:Intermediate_Filament_Protein rdf:type owl:Class ;
                               rdfs:subClassOf :Cytoskeletal_Protein ;
                               :Synonyms """Intermediate Filament Protein
IFP""" ;
                               :definition "Encoded by Intermediate Filament Genes, diverse Intermediate Filament Proteins (including keratin filaments, neurofilaments, desmin, and vimentin) form polymeric structural cytoplasmic filaments, intermediate in diameter (8-10 nanometer) between actin microfilaments and microtubules, that comprise part of the cytoskeleton of most eukaryotic cells." ;
                               :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20694" ;
                               rdfs:label "Intermediate Filament Protein" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#International_Normalized_Ratio
:International_Normalized_Ratio rdf:type owl:Class ;
                                rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ,
                                                :Coagulation_Study ;
                                :Synonyms """International Normalized Ratio
INR""" ;
                                :definition "A system, commonly called the INR, established by the World Health Organization (WHO) and the International Committee on Thrombosis and Hemostasis for reporting the results of blood coagulation (clotting) tests. All results are standardized using the international sensitivity index (ISI) for the particular thromboplastin reagent and instrument combination utilized to perform the test; the ratio of a patient's clotting time to the lab's mean reference value is normalized against the ISI." ;
                                :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C25352" ;
                                rdfs:label "International Normalized Ratio" .


