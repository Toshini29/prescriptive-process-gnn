###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Aminoglycoside_Antibiotic
:Aminoglycoside_Antibiotic rdf:type owl:Class ;
                           rdfs:subClassOf :Antibiotic ;
                           :Synonyms """Aminoglycoside Drugs
aminoglycoside antibiotic
Aminoglycoside Agents
Aminoglycoside Antibiotic
Aminoglycosides""" ;
                           :definition "Any antibiotic containing amino-modified sugars originally isolated from various Streptomyces and Micromonospora species. Aminoglycoside antibiotics bind to the 16S RNA of the bacterial 30S ribosomal subunit, inhibiting translation and protein synthesis. Aminoglycoside use is associated with ototoxicity, neurotxicity and nephrotoxicity." ;
                           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C2363" ;
                           rdfs:label "Aminoglycoside Antibiotic" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Ammonia
:Ammonia rdf:type owl:Class ;
         rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ;
         :Synonyms """Ammonia Solution, Strong
AMMONIA
Ammonia""" ;
         :definition "An inorganic compound composed of a single nitrogen atom covalently bonded to three hydrogen atoms that is an amidase inhibitor and neurotoxin. It is both manufactured and produced naturally from bacterial processes and the breakdown of organic matter. Ammonia is used in many industrial processes, and as a fertilizer and refrigerant. It is characterized as a colorless gas or compressed liquid with a pungent odor and exposure occurs by inhalation, ingestion, or contact." ;
         :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C76698" ;
         rdfs:label "Ammonia" .


