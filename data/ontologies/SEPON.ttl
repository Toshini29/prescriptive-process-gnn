                       :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C64857" ;
                       rdfs:label "Phosphate Measurement" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Phospholipase
:Phospholipase rdf:type owl:Class ;
               rdfs:subClassOf :Esterase ;
               :Synonyms """Phospholipase
Lecithinase""" ;
               :definition "Enzymes that catalyze the cleavage of a phospholipid molecule by the addition of water, thereby causing hydrolysis. The classification is based on the specificity of the bond cleaved. Hydrolytic activity initiates signaling cascades in the cell." ;
               :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16980" ;
               rdfs:label "Phospholipase" .


