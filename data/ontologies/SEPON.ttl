:Cell_Adhesion_Molecule_Gene rdf:type owl:Class ;
                             rdfs:subClassOf :Ligand_Binding_Protein_Gene ;
                             :Synonyms "Cell Adhesion Molecule Gene" ;
                             :definition "Cell Adhesion Molecule Genes encode diverse extracellular (e.g., laminin) and cell surface (e.g., NCAM) glycoproteins involved in cell-cell and cell-extracellular matrix adhesion, recognition, activation, tissue integration, wound healing, morphogenesis, and cellular migration." ;
                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20988" ;
                             rdfs:label "Cell Adhesion Molecule Gene" .


