###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Beta-Lactam_Antibiotic
:Beta-Lactam_Antibiotic rdf:type owl:Class ;
                        rdfs:subClassOf :Antibiotic ;
                        :Synonyms """Lactam Antibiotics
Beta-Lactam Antibiotic""" ;
                        :definition "A compound with a four member amide ring (beta-lactam), where one member is the amide nitrogen and another is the carbonyl carbon, with bactericidal activity. Beta-lactam antibiotics act by disrupting the synthesis of the peptidoglycan layer of the bacterial cell wall." ;
                        :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C260" ;
                        rdfs:label "Beta-Lactam Antibiotic" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Beta_Chemokine
:Beta_Chemokine rdf:type owl:Class ;
                rdfs:subClassOf :Chemokine ;
                :Synonyms """Beta Chemokine
CC Chemokine
Chemokine, CC
C-C Chemokine""" ;
                :definition "Encoded by CC Cytokine Genes, Beta Chemokines are CC-type dual-cysteine chemokines with adjacent cysteine residues in their primary sequence that act as chemoattractants for lymphocytes, monocytes, eosinophils, and basophils, but not for neutrophils." ;
                :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20476" ;
                rdfs:label "Beta Chemokine" .


