###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Epinephrine
:Epinephrine rdf:type owl:Class ;
             rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ;
             :Synonyms """Adrenaline Hydrochloride
Epifrin
Epinephrine Bitartrate
1,2-Benzenediol, 4-(1-hydroxy-2-(methylamino)ethyl)-, (R)-
Epinephrine Hydrochloride
Lyophrin
Adrenaline
Adrenaline Bitartrate
Acetate, Epinephrine
Epinephrine Acetate
4-(1-Hydroxy-2-(methylamino)ethyl)-1,2-benzenediol
Epinephrine Hydrogen Tartrate
Epitrate
Adrenaline Acid Tartrate
Medihaler-Epi""" ;
             :definition "The active sympathomimetic hormone from the ADRENAL MEDULLA. It stimulates both the alpha- and beta- adrenergic systems, causes systemic VASOCONSTRICTION and gastrointestinal relaxation, stimulates the HEART, and dilates BRONCHI and cerebral vessels. It is used in ASTHMA and CARDIAC FAILURE and to delay absorption of local ANESTHETICS." ;
             :reference "http://purl.bioontology.org/ontology/MESH/D004837" ;
             rdfs:label "Epinephrine" .


