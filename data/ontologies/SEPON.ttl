###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Indinavir
:Indinavir rdf:type owl:Class ;
           rdfs:subClassOf :HIV_Protease_Inhibitor ;
           :Synonyms """(1(1S,2R),5(S))-2,3,5-Trideoxy-N-(2,3-dihydro-2-hydroxy-1H-inden-1-yl)-5-(2-(((1,1-dimethylethyl)amino)carbonyl)-4-(3-pyridinylmethyl)-1-piperazinyl)-2-(phenylmethyl)-D-erythro-Pentonamide
Compound J
IDV
INDINAVIR
Indinavir
indinavir""" ;
           :definition "A synthetic hydroxyaminopentane amide agent that selectively inhibits the protease of both human immunodeficiency virus 1 and 2. The incorporation of a basic amine into the hydroxyethylene backbone improves its aqueous solubility and its oral bioavailability." ;
           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C66877" ;
           rdfs:label "Indinavir" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Indirect_Bilirubin_Measurement
:Indirect_Bilirubin_Measurement rdf:type owl:Class ;
                                rdfs:subClassOf :Liver_Function_Test ;
                                :Synonyms """Unconjugated Bilirubin Measurement
Indirect Bilirubin
Indirect Bilirubin Measurement
BILIND""" ;
                                :definition "Bilirubin is in the insoluble form, unconjugated bilirubin (indirect bilirubin).The non-water soluble, free bilirubin does not react with sulfanilic acid at acidic pH to produce a red colored complex until an accelearator, alcohol, is added to the solution to perform a quantitative measurement of unconjugated bilirubin levels." ;
                                :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C64483" ;
                                rdfs:label "Indirect Bilirubin Measurement" .


