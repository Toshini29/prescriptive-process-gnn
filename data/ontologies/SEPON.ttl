                                                            rdfs:subClassOf :Organism ;
                                                            :Synonyms """Archaebacteria
Mendosicutes
Metabacteria
Archaea""" ;
                                                            :definition "Single-celled organisms lacking nuclei, similar to prokaryotes in most aspects of cell structure and metabolism. However, their genetic transcription and translation do not show the typical bacterial features, but are extremely similar to those of eukaryotes." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C61092" ;
                                                            rdfs:label "Archaea" .


