###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Pharmacokinetics
:Pharmacokinetics rdf:type owl:Class ;
                  rdfs:subClassOf :Pharmacotherapy ;
                  :Synonyms """Pharmacokinetics
pharmacokinetics
PK""" ;
                  :definition "The characteristic movements of drugs within biological systems, as affected by absorption, distribution, binding, elimination, biotransformation, and excretion; particularly the rates of such movements." ;
                  :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C15299" ;
                  rdfs:label "Pharmacokinetics" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Pharmacologic_Substance
:Pharmacologic_Substance rdf:type owl:Class ;
                         rdfs:subClassOf :Pharmacotherapy ;
                         :Synonyms """Therapeutic Agent
therapeutic agents
Pharmacologic Agent
Pharmacologic Substance
Pharmaceutical Agent
Pharmaceuticals
Pharmacological Substance
Drug Substance
therapeutic_agents
Agent
DRUG
Drug
drug""" ;
                         :definition "Any natural, endogenously-derived, synthetic or semi-synthetic compound with pharmacologic activity. A pharmacologic substance has one or more specific mechanism of action(s) through which it exerts one or more effect(s) on the human or animal body. They can be used to potentially prevent, diagnose, treat or relieve symptoms of a disease. Formulation specific agents and some combination agents are also classified as pharmacologic substances." ;
                         :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C1909" ;
                         rdfs:label "Pharmacologic Substance" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Pharmacology
:Pharmacology rdf:type owl:Class ;
              rdfs:subClassOf :Pharmacotherapy ;
              :Synonyms """Pharmacologic
Pharmacological
pharmacology
Pharmacology
P""" ;
              :definition "The study of pharmacologic agents. This includes the preparation, compounding, and dispensing of drugs, as well as the characteristics and properties of drugs, their effects on the body, and how they are metabolized and eliminated from the body." ;
              :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16974" ;
              rdfs:label "Pharmacology" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Pharmacotherapy
:Pharmacotherapy rdf:type owl:Class ;
                 rdfs:subClassOf :Therapy ;
                 :Synonyms """Pharmacological Treatments
Treatment With Medication
drug therapy
Pharmacological Treatment
Pharmaceutical Therapy
Drug Therapy
Pharmaceutical Therapy, NOS
Pharmacotherapy""" ;
                 :definition "Treatment of disease through the use of drugs." ;
                 :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C15986" ;
                 rdfs:label "Pharmacotherapy" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Phenotype
:Phenotype rdf:type owl:Class ;
           rdfs:subClassOf :Diagnostic_Procedure ;
           :Synonyms """Phenotype
phenotype""" ;
           :definition "The assemblage of traits or outward appearance of an individual. It is the product of interactions between genes and between genes and the environment." ;
           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16977" ;
           rdfs:label "Phenotype" .


