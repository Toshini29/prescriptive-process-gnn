                           rdfs:subClassOf :Exogenous_Risk_Factor ;
                           :Synonyms """Environmental Factor
Environmental Risk Factor""" ;
                           :definition "Health hazards at home, in the work place, or in nature (e.g., infectious agents, irritants, respiratory fibrotic agents, asphyxiants, allergens, metabolic poisons, physical agents, mutagens, teratogens, and carcinogens). (Winett et al: Health Psychology and Public Health)" ;
                           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C18244" ;
                           rdfs:label "Environmental Risk Factor" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Enzyme
:Enzyme rdf:type owl:Class ;
        rdfs:subClassOf :Protein ;
        :Synonyms """Enzyme
Enzymes
enzyme""" ;
        :definition "Molecules that catalyze a chemical reaction. They are usually proteins, although catalytic RNA and DNA molecules have been identified." ;
        :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16554" ;
        rdfs:label "Enzyme" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Enzyme_Gene
:Enzyme_Gene rdf:type owl:Class ;
             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16612> ;
             :Synonyms "Enzyme Gene" ;
             :definition "Enzyme Genes encode Enzymes, biological molecules (usually proteins) that possess catalytic activity. Catalytic RNA and catalytic DNA molecules have also been identified." ;
             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C21281" ;
             rdfs:label "Enzyme Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Enzyme_Inhibitor_Gene
:Enzyme_Inhibitor_Gene rdf:type owl:Class ;
                       rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16612> ;
                       :Synonyms "Enzyme Inhibitor Gene" ;
                       :definition "Enzyme Inhibitor Genes encode Enzyme Inhibitor Proteins, biological molecules that block or suppress the catalytic activity of enzymes." ;
                       :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C29938" ;
                       rdfs:label "Enzyme Inhibitor Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Enzyme_Inhibitor_Protein
:Enzyme_Inhibitor_Protein rdf:type owl:Class ;
                          rdfs:subClassOf :Regulatory_Protein ;
                          :Synonyms "Enzyme Inhibitor Protein" ;
                          :definition "A class of proteins that are involved in the inhibition of enzymes." ;
