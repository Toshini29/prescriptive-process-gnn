###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Charlson_Comorbidity_Index
:Charlson_Comorbidity_Index rdf:type owl:Class ;
                            rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ,
                                            :Clinical_Assessment_Indicator ;
                            :Synonyms """Charlson Comorbidity Index
CCI""" ;
                            :definition "A method of predicting mortality risk or disease burden for patients with specific comorbid conditions. The conditions are assigned a weight from 1 to 6, based on ICD diagnosis codes, and these weights are summed to produce a single comorbidity score." ;
                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C176422" ;
                            rdfs:label "Charlson Comorbidity Index" .


