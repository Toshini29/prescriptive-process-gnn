###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12328
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12328> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """EPIDIDYMIS
Epididymal
Epididymis
epididymis""" ;
                                                            :definition "A crescent-like structure located in the upper and posterior surfaces of the testis. It consists of the efferent ductules and the duct of the epididymis. It facilitates the maturation of sperm that is produced in the testis." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12328" ;
                                                            rdfs:label "Epididymis" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12329
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12329> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Spermatic Cord
spermatic cord
Spermatic cord
testicular cord""" ;
                                                            :definition "A tube-like structure composed of the vas deferens and surrounding tissue layers, that runs from the abdomen to each of the testicles." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12329" ;
                                                            rdfs:label "Spermatic Cord" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12339
