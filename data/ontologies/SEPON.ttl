###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Proteinase_Inhibitor_Gene
:Proteinase_Inhibitor_Gene rdf:type owl:Class ;
                           rdfs:subClassOf :Enzyme_Inhibitor_Gene ;
                           :Synonyms "Proteinase Inhibitor Gene" ;
                           :definition "Proteinase Inhibitor Genes encode Proteinase Inhibitor Proteins that block the activity of proteases, endopeptidases that catalyze the cleavage of internal peptide bonds in a polypeptide or protein substrate (Serine Endopeptidases, Cysteine Endopeptidases, Aspartic Endopeptidases, Metalloendopeptidases, and other Endopeptidases)." ;
                           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C29936" ;
                           rdfs:label "Proteinase Inhibitor Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Prothrombin_Time
:Prothrombin_Time rdf:type owl:Class ;
                  rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ,
                                  :Coagulation_Study ;
                  :Synonyms """Prothrombin Time Test
Prothrombin Time
PT""" ;
                  :definition "A measurement of the clotting time of plasma recalcified in the presence of excess tissue thromboplastin; it is a measure of the extrinsic pathway of coagulation. It is used to determine the clotting tendency of blood, in the measure of warfarin dosage, liver damage and vitamin K status. Factors measured are fibrinogen, prothrombin, and factors V, VII, and X." ;
                  :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C62656" ;
                  rdfs:label "Prothrombin Time" .


