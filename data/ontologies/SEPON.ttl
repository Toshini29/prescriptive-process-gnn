                                                                           rdfs:label "Acute Physiology and Chronic Health Evaluation II Clinical Classification" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Acyclovir
:Acyclovir rdf:type owl:Class ;
           rdfs:subClassOf :Antiviral_Agent ;
           :Synonyms """9-[(2-Hydroxyethoxy)-methyl]guanine
Wellcome-248U
2-Amino-1,9-dihydro-9-[(2-hydroxyethoxy)methyl]-6H-purin-6-one
9-[(2-Hydroxyethoxy)methyl]guanine
Acycloguanosine
ACV
ACYCLOVIR
Acicloftal
Aciclovir
Aclovir
Acyclovir
BW-248U
Cargosil
Virorax
Zovirax
acyclovir""" ;
           :definition "A synthetic analog of the purine nucleoside, guanosine, with potent antiviral activity against herpes simplex viruses type 1 and 2, varicella-zoster virus and other viruses of the herpesvirus family. After conversion in vivo to the active metabolite acyclovir triphosphate by viral thymidine kinase, acyclovir competitively inhibits viral DNA polymerase by incorporating into the growing viral DNA chain and terminating further polymerization." ;
           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C205" ;
           rdfs:label "Acyclovir" .


