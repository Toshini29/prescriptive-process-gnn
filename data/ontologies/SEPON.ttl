###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cell_Adhesion_Molecule
:Cell_Adhesion_Molecule rdf:type owl:Class ;
                        rdfs:subClassOf :Ligand_Binding_Protein ;
                        :Synonyms """Adhesion Molecule
Cell Adhesion Molecule
CAM
CAMs""" ;
                        :definition "A diverse family of cell surface and extracellular glycoproteins involved in cell-cell adhesion, cell-extracellular matrix adhesion, recognition, and activation. There are four main classes of cell adhesion molecules: integrins, selectins, cadherins, and immunoglobulin-like adhesion molecules." ;
                        :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16393" ;
                        rdfs:label "Cell Adhesion Molecule" .


