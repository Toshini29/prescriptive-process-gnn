:Collagen rdf:type owl:Class ;
          rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ,
                          :Extracellular_Matrix_Protein .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Collagen_Gene
:Collagen_Gene rdf:type owl:Class ;
               rdfs:subClassOf :Extracellular_Matrix_Protein_Gene ;
               :Synonyms "Collagen Gene" ;
               :definition "Collagen Genes encode different forms of Collagen, the principle fibrous protein of connective tissue, all consisting of triple helix alpha-polypeptide chains. Collagen is differentiated from other fibrous proteins by its content of proline, hydroxyproline, and hydroxylysine; by its absence of tryptophan; and by its high content of polar groups. Hydroxyproline residues likely promote the triple helical fibrous structure of collagen." ;
               :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C26001" ;
               rdfs:label "Collagen Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Colony-Stimulating_Factor_Gene
:Colony-Stimulating_Factor_Gene rdf:type owl:Class ;
                                rdfs:subClassOf :Hematopoietic_Factor_Gene ;
                                :Synonyms "Colony-Stimulating Factor Gene" ;
                                :definition "Colony-Stimulating Factor Genes encode Colony-Stimulating Factors, autocrine or paracrine glycoprotein growth factors that act synergistically on several bone marrow progenitor cells to regulate myeloid differentiation and stimulate production of blood cells." ;
                                :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C26047" ;
                                rdfs:label "Colony-Stimulating Factor Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Colony_Stimulating_Factor
:Colony_Stimulating_Factor rdf:type owl:Class ;
                           rdfs:subClassOf :Hematopoietic_Growth_Factor ;
                           :Synonyms """colony-stimulating factor
Colony-Stimulating Factors
MGI-1 Protein
Colony Stimulating Factor
Myeloid Cell-Growth Inducer
CSF
MGI-1""" ;
                           :definition "A substance that stimulates the production of blood cells. Colony-stimulating factors include granulocyte colony-stimulating factor (G-CSF), granulocyte-macrophage colony-stimulating factor (GM-CSF), and promegapoietin." ;
                           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20586" ;
                           rdfs:label "Colony Stimulating Factor" .


