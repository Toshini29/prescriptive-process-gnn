###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13010
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13010> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712> ;
                                                            :Synonyms """Brunner's Gland
GLAND, BRUNNER'S
Brunner's Glands""" ;
                                                            :definition "Compound, tubular, submucosal glands located in the duodenum proximal to the sphincter of Oddi; these glands produce alkaline-rich secretions that function to both protect the duodenum from the acidic content of the stomach and to enable intestinal enzymes to activate, thus enabling absorption to start." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13010" ;
                                                            rdfs:label "Brunner's Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12219> ;
                                                            :Synonyms """Organ
Organs
organ""" ;
                                                            :definition "A unique macroscopic anatomic structure that performs specific functions. It is composed of various tissues. An organ is part of an anatomic system or a body region." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018" ;
                                                            rdfs:label "Organ" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13048
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13048> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33461> ;
                                                            :Synonyms """Uriniferous Tube
Nephron""" ;
                                                            :definition "The basic structural and functioning unit of the kidney. It is composed of the glomerulus, where waste products are filtered from the blood, the proximal and distal tubules, the loop of Henle, and the collecting ducts, where urine is produced for excretion from the body." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13048" ;
                                                            rdfs:label "Nephron" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13049
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13049> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C41168> ;
                                                            :Synonyms """Lymphoid Normal
Lymphoid Tissue""" ;
                                                            :definition "Tissue characterized by the presence of large numbers of lymphocytes in different stages of transformation. Connective tissue cells including fibroblasts and macrophages may be present. Lymphoid tissue is framed by a network of reticular fibers and may be diffuse, or densely aggregated." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13049" ;
                                                            rdfs:label "Lymphoid Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13051
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13051> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C41168> ;
                                                            :Synonyms """Hematopoietic Tissue
hematopoietic tissue""" ;
                                                            :definition "Tissue in which new blood cells are formed." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13051" ;
                                                            rdfs:label "Hematopoietic Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13052
