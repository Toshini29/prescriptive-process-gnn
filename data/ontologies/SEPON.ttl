                         rdfs:label "Electrolyte Measurement" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Electrolyte_Replacement_Agent
:Electrolyte_Replacement_Agent rdf:type owl:Class ;
                               rdfs:subClassOf :Pharmacologic_Substance ;
                               :Synonyms "Electrolyte Replacement Agent" ;
                               :definition "Any agent or mixture of agents that are used to replenish electrolytes in body fluids, such as sodium, potassium, calcium, magnesium, phosphorus, chloride and bicarbonate." ;
                               :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C29730" ;
                               rdfs:label "Electrolyte Replacement Agent" .


