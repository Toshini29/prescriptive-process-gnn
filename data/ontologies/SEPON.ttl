###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Zanamivir
:Zanamivir rdf:type owl:Class ;
           rdfs:subClassOf :Antiviral_Agent ;
           :Synonyms """4-Guanidino-2,4-dideoxy-2,3-dehydro-N-acetylneuraminic Acid
5-Acetamido-2,6-anhydro-3,4,5-trideoxy-4-guanidino-D-glycero-D-galacto-non-2-enonic Acid
GANA
GG 167
Relenza
ZANAMIVIR
Zanamivir
zanamivir""" ;
           :definition "A sialic acid-analogue neuraminidase inhibitor with antiviral activity. Administered into the respiratory tract by aerosol inhalation, zanamivir selectively binds to and inhibits influenza A and B virus neuraminidase-mediated cleavage of sialic acid residues in host cell membrane-bound glycoprotein receptors for influenza viruses, preventing the release of progeny viruses from host cell surfaces and, so, further viral replication." ;
           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C47786" ;
           rdfs:label "Zanamivir" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Zidovudine
:Zidovudine rdf:type owl:Class ;
            rdfs:subClassOf :Nucleoside_Reverse_Transcriptase_Inhibitor ;
            :Synonyms """3'-Azido-3'-deoxythymidine
1-(3-Azido-2,3-dideoxy-beta-D-ribofuranosyl)-5-methylpyrimidine-2,4-(1H,3H)-dione
Azidothymidine
AZT
Aztec
BW A509U
BW-A 509U
BW-A509U
Compound S
DRG-0004
Retrovir
ZDV
ZIDOVUDINE
Zidovudine
zidovudine""" ;
            :definition "A synthetic dideoxynucleoside. After intracellular phosphorylation to its active metabolite, zidovudine inhibits DNA polymerase, resulting in the inhibition of DNA replication and cell death. This agent also decreases levels of available pyrimidines." ;
            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C947" ;
            rdfs:label "Zidovudine" .


