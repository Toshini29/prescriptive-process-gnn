###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13418
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13418> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13236> ;
                                                            :Synonyms """Head and Neck-Fluids, Secretions
Head and Neck, Fluids, Secretions
Head and Neck Fluids and Secretions""" ;
                                                            :definition "Secretions and fluids from the area of the body generally construed to comprise base of skull and facial bones, sinuses, orbits, salivary glands, oral cavity, oropharynx, larynx, thyroid, facial and neck musculature and lymph nodes draining these areas." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13418" ;
                                                            rdfs:label "Head and Neck Fluids and Secretions" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13430
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13430> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13202> ;
                                                            :Synonyms "Mitotic Chromosome" ;
                                                            :definition "Condensed chromosomes observed during the M phase of the cell cycle. Individual chromosomes can be discerned and differentiated morphologically." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13430" ;
                                                            rdfs:label "Mitotic Chromosome" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13431
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13431> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13202> ;
                                                            :Synonyms "Interphase Chromosome" ;
                                                            :definition "Interphase chromosomes are decondensed chromosomes that reside in the interphase nucleus in the form of chromatin. Two types of chromatin, euchromatin and heterochromatin, can be discerned microscopically." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13431" ;
                                                            rdfs:label "Interphase Chromosome" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13433
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13433> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13434> ;
                                                            :Synonyms """30 nm Fiber
Chromatin Fibril
Chromatin Fiber
30 nm Chromatin Fiber""" ;
                                                            :definition "A level of DNA packaging in chromatin above that of the nucleosome, the fundamental subunit of chromatin structure. The chromatin fiber has a thickness of about 30 nanometers and results from the folding of a linear array of nucleosomes (thickness about 10 nm) into a more compact fiber." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13433" ;
                                                            rdfs:label "Chromatin Fiber" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13434
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13434> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13402> ;
                                                            :Synonyms """Higher Order Chromatin Structure
Higher Order Chromatin Folding
Higher Order Structure""" ;
                                                            :definition "Refers to various levels of DNA packaging in the chromosomes above that of the nucleosome. Includes the chromatin fiber and higher levels of folding such as loops." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13434" ;
                                                            rdfs:label "Higher Order Chromatin Structure" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13435
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13435> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13434> ;
                                                            rdfs:label "Chromatin Loop" .


