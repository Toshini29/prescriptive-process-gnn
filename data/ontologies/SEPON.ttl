#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Caused_By
:Caused_By rdf:type owl:ObjectProperty ;
           rdfs:domain :Etiology ;
           rdfs:range :Complication ,
                      :Phenotype ,
                      :Subtype ;
           :Synonyms "Caused By" ;
           :definition "A relationship between a condition (a phenotype or disease) and an entity (e.g. environment) or condition (phenotype or disease) which could be an existing condition or an event, where the entity or second condition has a causal role for the condition being described." ;
           :reference "http://purl.obolibrary.org/obo/SCDO_1000202" ;
           rdfs:label "Caused_By" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Differential_Diagnosis
:Differential_Diagnosis rdf:type owl:ObjectProperty ;
                        rdfs:domain :Phenotype ,
                                    :Subtype ;
                        rdfs:range :Phenotype ,
                                   :Subtype ;
                        :Synonyms "Differential_Diagnosis" ;
                        rdfs:label "Differential_Diagnosis" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Drug_Target
:Drug_Target rdf:type owl:ObjectProperty ;
             rdfs:domain :Pharmacologic_Substance ;
             rdfs:range <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16612> ;
             :Synonyms """Drug_Target
drug has protein target""" ;
             :definition "An object property that represents a relation between a drug and a protein where the drug can target the protein." ;
             :reference "http://purl.obolibrary.org/obo/CIDO_0000124" ;
             rdfs:label "Drug_Target" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Has_Complication
:Has_Complication rdf:type owl:ObjectProperty ;
                  rdfs:domain :Phenotype ,
                              :Subtype ;
                  rdfs:range :Complication ;
                  :Synonyms "Has_Complication" ;
                  rdfs:label "Has_Complication" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Has_Diagnostic_Biomarker
:Has_Diagnostic_Biomarker rdf:type owl:ObjectProperty ;
                          rdfs:domain :Phenotype ,
                                      :Subtype ;
                          rdfs:range :Diagnostic_Biomarker ;
                          :Synonyms "Has_Diagnostic_Biomarker" ;
                          rdfs:label "Has_Diagnostic_Biomarker" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Has_Diagnostic_Imaging
:Has_Diagnostic_Imaging rdf:type owl:ObjectProperty ;
                        rdfs:domain :Phenotype ,
                                    :Subtype ;
                        rdfs:range :Imaging_Finding ;
                        :Synonyms "Has_Diagnostic_Imaging" ;
                        rdfs:label "Has_Diagnostic_Imaging" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Has_Disease
:Has_Disease rdf:type owl:ObjectProperty ;
             rdfs:domain <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16960> ;
             rdfs:range :Phenotype ,
                        :Subtype ;
             :Synonyms "Has_Disease" ;
             rdfs:label "Has_Disease" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Has_Drug
:Has_Drug rdf:type owl:ObjectProperty ;
          rdfs:domain :Phenotype ,
                      :Subtype ;
          rdfs:range :Pharmacologic_Substance ;
          :Synonyms "Has_Drug" ;
          rdfs:label "Has_Drug" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Has_Prognostic_Biomarker
