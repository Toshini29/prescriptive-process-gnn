:Therapeutic_Procedure rdf:type owl:Class ;
                       rdfs:subClassOf <http://purl.bioontology.org/ontology/ICD9CM/995.91> ;
                       :Synonyms """Therapeutic Procedure
Therapeutic
Therapeutic Technique
any_therapy
treatment or therapy
Therapeutic Method
Therapeutic Interventions
treatment_or_therapy
any therapy
TREAT
TX
Therapy
Treatment
therapy
treatment""" ;
                       :definition "An action or administration of therapeutic agents to produce an effect that is intended to alter or stop a pathologic process." ;
                       :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C49236" ;
                       rdfs:label "Therapeutic Procedure" .


