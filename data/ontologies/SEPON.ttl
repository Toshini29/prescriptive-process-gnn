                    rdfs:subClassOf :Antiprotozoal_Agent ;
                    :Synonyms """Anti-Malarial Drug
Antimalarials
Antimalarial Drugs
Anti-Malarial Agent
Antimalarial Agent""" ;
                    :definition "Agents used to treat malaria, and are usually classified based on action against plasmodia at different stages in their life cycle in the human." ;
                    :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C271" ;
                    rdfs:label "Antimalarial Agent" .


