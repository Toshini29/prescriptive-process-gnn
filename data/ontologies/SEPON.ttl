###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Ganciclovir
:Ganciclovir rdf:type owl:Class ;
             rdfs:subClassOf :Antiviral_Agent ;
             :Synonyms """GANCICLOVIR
Nordeoxyguanosine
ganciclovir
9-[(1,3-Dihydroxy-2-propoxy)methyl]guanine
2-Amino-1,9-[[2-hydroxy-1-(hydroxymethyl)ethoxy]methyl]-6H-purin-6-one
2'-Nor-2'-deoxyguanosine
Ganciclovir
2'NDG
Cymevan
DHPG
GCV
Virgan""" ;
             :definition "A synthetic guanine derivative with antiviral activity. As the active metabolite of ganciclovir, ganciclovir-5-triphosphate (ganciclovir-TP) appears to inhibit viral DNA synthesis by competitive inhibition of viral DNA polymerases and incorporation into viral DNA, resulting in eventual termination of viral DNA elongation." ;
             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C517" ;
             rdfs:label "Ganciclovir" .


