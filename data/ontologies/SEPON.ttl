###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Type_A_Personality
:Type_A_Personality rdf:type owl:Class ;
                    rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C38002> ;
                    :Synonyms "Personality, Type A" ;
                    :definition "Established behavior pattern characterized by excessive drive and ambition, impatience, competitiveness, sense of time urgency, and poorly contained aggression." ;
                    :reference "http://purl.bioontology.org/ontology/MESH/D014434" ;
                    rdfs:label "Type A Personality" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Type_B_Personality
:Type_B_Personality rdf:type owl:Class ;
                    rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C38002> ;
                    :Synonyms "B Personalities, Type" ;
                    :definition "Behavior pattern characterized by a generally calm and even-tempered demeanor. Emotionally, such personality types show less frequent irritation, anger, hostility, and aggression than Type A individuals." ;
                    :reference "http://purl.bioontology.org/ontology/MESH/D064414" ;
                    rdfs:label "Type B Personality" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Type_D_Personality
:Type_D_Personality rdf:type owl:Class ;
                    rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C38002> ;
                    :Synonyms "Personality Type Ds" ;
                    :definition "Behavior pattern characterized by negative emotionality, an inability to express emotions, and social isolation, which has been linked to greater cardiovascular disease and increased mortality." ;
                    :reference "http://purl.bioontology.org/ontology/MESH/D064415" ;
                    rdfs:label "Type D Personality" .


