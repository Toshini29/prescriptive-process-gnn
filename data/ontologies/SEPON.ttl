                      :definition "Medicine to stop, prevent, or control seizures (convulsions)." ;
                      :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C264" ;
                      rdfs:label "Anticonvulsant Agent" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Antifungal_Agent
:Antifungal_Agent rdf:type owl:Class ;
                  rdfs:subClassOf :Anti-Infective_Agent ;
                  :Synonyms """Antifungal Agent
Antifungals
Antifungal Drug
Antifungal
antifungal""" ;
                  :definition "Substances that treat systemic or topical infections caused by fungi. Antifungal agents kill or inhibit the growth of fungi, by various mechanisms. These mechanisms include inhibition of fungal mitosis, impairing synthesis or binding to ergosterol, inhibition of RNA or DNA synthesis, and interfering with other fungal metabolic processes." ;
                  :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C514" ;
                  rdfs:label "Antifungal Agent" .


