###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Heart_Murmur
:Heart_Murmur rdf:type owl:Class ;
              rdfs:subClassOf :Cardiovascular_System_Signs_and_Symptoms ;
              :Synonyms """Heart Murmur
Heart murmur
Cardiac Murmur
Murmur""" ;
              :definition "A periodic humming or blowing sound heard on auscultation of the heart that can indicate the presence of cardiac disease; murmurs are the result of vibrations caused by the turbulent flow of blood in the heart or great vessels. Murmurs are characterized according to the area of generation (mitral, aortic, tricuspid, or pulmonary) and according to the period of the cycle (systolic or diastolic)." ;
              :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C84480" ;
              rdfs:label "Heart Murmur" .


