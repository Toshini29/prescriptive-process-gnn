:Lysophosphatidylcholine rdf:type owl:Class ;
                         rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ;
                         :Synonyms """lysophosphatidylcholines
monoacylglycero-3-phosphocholine
LPC""" ;
                         :definition "An acylglycerophosphocholine resulting from partial hydrolysis of a phosphatidylcholine, which removes one of the fatty acyl groups. The structure is depicted in the image where R1 = acyl, R2 = H or where R1 = H, R2 = acyl." ;
                         :reference "http://purl.obolibrary.org/obo/CHEBI_60479" ;
                         rdfs:label "Lysophosphatidylcholine" .


