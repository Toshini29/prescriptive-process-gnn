R SV""" ;
                                                             :definition "The seminal gland that is located to the anatomical right of the bladder." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C128611" ;
                                                             rdfs:label "Right Seminal Vesicle" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12886
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12886> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33461> ;
                                                            :Synonyms "Renal Pyramid" ;
                                                            :definition "A cone-shaped structure of the kidney. It is located in the medullary portion of the kidney (pyramid of Malpighi) or the cortical portion of the kidney (pyramid of Ferrein)." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12886" ;
                                                            rdfs:label "Renal Pyramid" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12905
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12905> rdf:type owl:Class ;
