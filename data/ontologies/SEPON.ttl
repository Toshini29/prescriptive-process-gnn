:Critical_Care_Pain_Observation_Tool rdf:type owl:Class ;
                                     rdfs:subClassOf :Pain_Assessment ;
                                     :Synonyms """Critical Care Pain Observation Tool
CPOT""" ;
                                     rdfs:label "Critical Care Pain Observation Tool" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Crosslinked_Multimeric_Type_III_Procollagen_Propeptide
:Crosslinked_Multimeric_Type_III_Procollagen_Propeptide rdf:type owl:Class ;
                                                        rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ,
                                                                        :Paediatric_Sepsis_Prognostic_Biomarker ;
                                                        :Synonyms """Cross-Linked Multimeric PRO-C3
Crosslinked Multimeric Type III Procollagen N-Terminal Peptide
Crosslinked Type III Procollagen N-Terminal Peptide Multimers
Crosslinked Multimeric Type III Procollagen Propeptide
Crosslinked Type III Procollagen Propeptide Multimers
Cross-Linked Multimeric Type III Procollagen Propeptide
XM-PRO-C3
Procollagen Type III amino-terminal propeptide
PIIINP
COL3A1""" ;
                                                        :definition "Crosslinked complexes comprised of multiple copies of the N-terminal propeptide derived from type III procollagen. Quantitation of the level of these peptides in blood samples may serve as a marker for liver fibrosis or steatosis." ;
                                                        :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C176686" ;
                                                        rdfs:label "Crosslinked Multimeric Type III Procollagen Propeptide" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cryoglobulin_Volume_to_Serum_Volume_Ratio_Measurement
:Cryoglobulin_Volume_to_Serum_Volume_Ratio_Measurement rdf:type owl:Class ;
                                                       rdfs:subClassOf :Serum_Chemistry_Measurement ;
                                                       :Synonyms """Cryoglobulin Volume to Serum Volume Ratio Measurement
Cryoglobulin Volume/Serum Volume
CRYGLBSR""" ;
                                                       :definition "The determination of the ratio of cryoglobulin volume compared to serum volume present in a sample. The measurement may be expressed as a ratio or percentage." ;
                                                       :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C147325" ;
                                                       rdfs:label "Cryoglobulin Volume to Serum Volume Ratio Measurement" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cystatin-C
:Cystatin-C rdf:type owl:Class ;
            rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ,
                            :Enzyme_Inhibitor_Protein .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cystatin_Family_Gene
:Cystatin_Family_Gene rdf:type owl:Class ;
                      rdfs:subClassOf :Cystatin_Superfamily_Gene ;
                      :Synonyms """Cystatin 2 Family Gene
Cystatin Family Gene""" ;
                      :definition "Cystatin Family Genes encode (Type 2) Cystatin proteins, secreted, tight, reversible, competitive inhibitors of cysteine proteinases that contain multiple cystatin-like sequences and have 2 intrachain disulfide bonds. Cystatin Superfamily Genes comprise three subfamilies that display structural and/or functional similarities: Stefins (Type 1 Cystatins), Cystatins (Type 2 Cystatins), and Kininogens. Some members are active cysteine protease inhibitors; others have lost or never acquired inhibitory activity." ;
                      :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20727" ;
                      rdfs:label "Cystatin Family Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cystatin_Superfamily_Gene
:Cystatin_Superfamily_Gene rdf:type owl:Class ;
                           rdfs:subClassOf :Cysteine_Proteinase_Inhibitor_Gene ;
                           :Synonyms "Cystatin Superfamily Gene" ;
                           :definition "Cystatin Superfamily Genes comprise a single evolutionary superfamily that encode protein subfamilies with functional and structural similarities that include cystatin-like sequences: Stefins (Type 1 Cystatins), Cystatins (Type 2 Cystatins), and Kininogens. Some members are active cysteine protease inhibitors; others have lost or never acquired inhibitory activity. Cystatins are intracellular or extracellular, tight, reversible, competitive inhibitors of lysosomal cysteine proteinases, such as Cathepsins B, L, H, and S, that appear to provide a protective function. Type 1 Cystatins lack disulfide bridges. Type 2 Cystatins are secreted and have 2 intrachain disulfide bonds. Kininogens contain 3 cystatin-like domains, each with 2 disulfide bonds." ;
                           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20726" ;
                           rdfs:label "Cystatin Superfamily Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cysteine-rich_Transmembrane_Module_Containing_1
:Cysteine-rich_Transmembrane_Module_Containing_1 rdf:type owl:Class ;
                                                 rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ,
                                                                 :Enzyme_Inhibitor_Protein .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cysteine_Proteinase_Inhibitor_Gene
:Cysteine_Proteinase_Inhibitor_Gene rdf:type owl:Class ;
                                    rdfs:subClassOf :Proteinase_Inhibitor_Gene ;
                                    :Synonyms "Cysteine Proteinase Inhibitor Gene" ;
                                    :definition "Human Cysteine Proteinase Inhibitor Genes encode Cysteine Proteinase Inhibitors, endogenous proteins that hinder the function of cysteine proteinases." ;
                                    :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20725" ;
                                    rdfs:label "Cysteine Proteinase Inhibitor Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cytochrome
:Cytochrome rdf:type owl:Class ;
            rdfs:subClassOf :Oxygenase ;
            :Synonyms """Cytochromes
Cytochrome""" ;
            :definition "A family of membrane-associated, heme-containing proteins that catalyze oxidation and reduction to promote electron transport reactions." ;
            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16486" ;
            rdfs:label "Cytochrome" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cytochrome_P450
:Cytochrome_P450 rdf:type owl:Class ;
                 rdfs:subClassOf :Cytochrome ;
                 :Synonyms """Cytochrome-P450
Cytochrome P450 Family
Cytochrome P450 Protein
Cytochrome P450 Enzyme
cytochrome P450 enzyme system
Cytochrome P-450
Cytochrome P450
CYP
CYP450
P450""" ;
                 :definition "A family of cytochromes that are involved in electron transport and oxidative metabolism of drugs and other bioactive molecules. When the catalytic heme is reduced the absorbance peak for this protein occurs at 450 nm." ;
                 :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16484" ;
                 rdfs:label "Cytochrome P450" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cytochrome_P450_1B1
:Cytochrome_P450_1B1 rdf:type owl:Class ;
                     rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ,
                                     :Cytochrome_P450 .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cytochrome_P450_Family_Gene
:Cytochrome_P450_Family_Gene rdf:type owl:Class ;
                             rdfs:subClassOf :Oxidoreductase_Gene ;
                             :Synonyms "Cytochrome P450 Family Gene" ;
                             :definition "Cytochrome P450 Family Genes encode Cytochrome P450 isozymes, hemoprotein components of the mixed-function oxidase system involving electron and/or hydrogen transport through reversible valency change of the heme iron and metabolic biotransformation of substances, including foreign compounds to mutagens and carcinogens." ;
                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C26511" ;
                             rdfs:label "Cytochrome P450 Family Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cytokine
:Cytokine rdf:type owl:Class ;
          rdfs:subClassOf :Protein ;
          :Synonyms """Cytokine
Cytokines
cytokine""" ;
          :definition "A class of soluble glycoproteins which act nonenzymatically through specific receptors to regulate immune responses. Cytokines are derived from both immune and non-immune cells and are intercellular mediators that differ from hormones in that they are produced by a number of tissue or cell types rather than by specialized glands." ;
          :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20464" ;
          rdfs:label "Cytokine" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cytokine_Gene
:Cytokine_Gene rdf:type owl:Class ;
               rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16612> ;
               :Synonyms "Cytokine Gene" ;
               :definition "Cytokines are soluble glycoproteins released by cells of the immune system, which act nonenzymatically through specific receptors to regulate immune responses. Cytokines resemble hormones in that they act at low concentrations and bind with high affinity to a specific receptor." ;
               :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C21550" ;
               rdfs:label "Cytokine Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cytokine_Receptor
:Cytokine_Receptor rdf:type owl:Class ;
                   rdfs:subClassOf :Receptor ;
                   :Synonyms "Cytokine Receptor" ;
                   :definition "A cytokine receptor is a protein on the cell surface that specifically binds cytokine ligands which are small proteins secreted by immune cells. These receptors mediate molecular functions such as signal transduction." ;
                   :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17667" ;
                   rdfs:label "Cytokine Receptor" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cytokine_Receptor_Gene
:Cytokine_Receptor_Gene rdf:type owl:Class ;
                        rdfs:subClassOf :Receptor_Gene ;
                        :Synonyms "Cytokine Receptor Gene" ;
                        :definition "Cytokine Receptor Genes encode cell surface Cytokine Receptors that bind paracrine or autocrine cytokine growth factors that stimulate humoral and cellular immune responses, as well as activation of phagocytic cells. Cytokines are secreted by inflammatory leukocytes (lymphokines), by monocytes or macrophages (monokines), and by various other cells. Interleukin lymphokines, targeted to cells of hematopoietic origin, are not secreted by leukocytes but affect the cellular responses of leukocytes." ;
                        :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20912" ;
                        rdfs:label "Cytokine Receptor Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cytoskeletal_Gene
:Cytoskeletal_Gene rdf:type owl:Class ;
                   rdfs:subClassOf :Structural_Protein_Gene ;
                   :Synonyms """Cytoskeletal Protein Gene
Cytoskeletal Gene""" ;
                   :definition "Cytoskeletal Genes encode Cytoskeletal Proteins, diverse structural proteins including polymerizable globular subunits (actin, tubulin), \"motor ATPases\" (myosin, dynein), membrane-supporting linkers (spectrin, clathrin), fibrous proteins (keratin, vimentin), and many more. As constituents of the cytoskeleton, Cytoskeletal Proteins form a flexible cellular framework that provides attachment points for organelles and formed bodies and makes communication between cell parts possible." ;
                   :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20745" ;
                   rdfs:label "Cytoskeletal Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cytoskeletal_Protein
:Cytoskeletal_Protein rdf:type owl:Class ;
                      rdfs:subClassOf :Structural_Protein ;
                      :Synonyms "Cytoskeletal Protein" ;
                      :definition "A protein that is a structural part of the cytoskeleton. These proteins are involved in cell shape, organelle and protein localization, cell movement, cell division, endocytosis, exocytosis, and signal transduction." ;
                      :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16492" ;
                      rdfs:label "Cytoskeletal Protein" .


