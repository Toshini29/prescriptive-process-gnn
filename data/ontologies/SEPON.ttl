                                                            :Synonyms """Pre-Condensed Chromosomes
Genetics, Pre-Condensed Chromosomes""" ;
                                                            :definition "It refers to the chromosome status during the prophase of mitotic division." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13451" ;
                                                            rdfs:label "Pre-Condensed Chromosomes" .


