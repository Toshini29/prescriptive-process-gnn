###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Pain_Assessment
:Pain_Assessment rdf:type owl:Class ;
                 rdfs:subClassOf :Clinical_Assessment_Indicator ;
                 :Synonyms """Pain Measurement
Pain Assessment
Pain Score
Analgesia Measurement
Analgesia Assessment
Analgesia Score""" ;
                 :definition "The evaluation of pain complaints. Measurements should be objective on the part of the practitioner, based on subjective information from the patient. Measurements may also be indirect, by such assessments as respiratory rate and effort, withdrawal, guarding, or other appropriate assessment techniques." ;
                 :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20992" ;
                 rdfs:label "Pain Assessment" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Pain_Therapy
:Pain_Therapy rdf:type owl:Class ;
              rdfs:subClassOf :Therapy ;
              :Synonyms """Pain, Pain Management
Pain Therapy
Pain Control
Pain Management
Analgesia
analgesia""" ;
              :definition "(i) the systematic study of clinical and basic science and its application for the reduction of pain and suffering; (ii) the blending of tools, techniques and principles taken from the discrete healing art disciplines and reformulated as a holistic application for the reduction of pain and suffering; and (iii) a newly emerging discipline emphasizing an interdisciplinary approach with a goal of reduction of pain and suffering." ;
              :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C15180" ;
              rdfs:label "Pain Therapy" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Palpitation
:Palpitation rdf:type owl:Class ;
             rdfs:subClassOf :Cardiovascular_System_Signs_and_Symptoms ;
             :Synonyms """palpitation
Heart Palpitations
Palpitations
Palpitation""" ;
             :definition "An unpleasant sensation of irregular and/or forceful beating of the heart." ;
             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C37999" ;
             rdfs:label "Palpitation" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Partial_Pressure_Arterial_Oxygen_to_Fraction_Inspired_Oxygen_Ratio_Measurement
:Partial_Pressure_Arterial_Oxygen_to_Fraction_Inspired_Oxygen_Ratio_Measurement rdf:type owl:Class ;
                                                                                rdfs:subClassOf :Gas_Measurement ;
                                                                                :Synonyms """Partial Pressure Arterial Oxygen to Fraction Inspired Oxygen Ratio Measurement
PP Arterial O2/Fraction Inspired O2
PAO2/FIO2
PO2FIO2""" ;
                                                                                :definition "The determination of the ratio of the pressure of oxygen dissolved in arterial blood to the percentage oxygen of an inhaled mixture of gasses in a biological specimen." ;
                                                                                :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C119293" ;
                                                                                rdfs:label "Partial Pressure Arterial Oxygen to Fraction Inspired Oxygen Ratio Measurement" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Partial_Pressure_of_Carbon_Dioxide_Measurement
:Partial_Pressure_of_Carbon_Dioxide_Measurement rdf:type owl:Class ;
                                                rdfs:subClassOf :Gas_Measurement ;
                                                :Synonyms """Partial Pressure of Carbon Dioxide Measurement
Partial Pressure Carbon Dioxide
PCO2""" ;
                                                :definition "A measurement of the partial pressure of carbon dioxide in a sample." ;
                                                :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C82625" ;
                                                rdfs:label "Partial Pressure of Carbon Dioxide Measurement" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Partial_Pressure_of_Oxygen_Measurement
:Partial_Pressure_of_Oxygen_Measurement rdf:type owl:Class ;
                                        rdfs:subClassOf :Gas_Measurement ;
                                        :Synonyms """Partial Pressure of Oxygen
Partial Pressure Oxygen
Partial Pressure O2
Partial Pressure of Oxygen Measurement
PO2
PaO2
Po2
pO2""" ;
                                        :definition "Measures the pressure of oxygen dissolved in the blood and how well oxygen is able to move from the airspace of the lungs into the blood." ;
                                        :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C71251" ;
                                        rdfs:label "Partial Pressure of Oxygen Measurement" .


