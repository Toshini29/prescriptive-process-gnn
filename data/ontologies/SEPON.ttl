               rdfs:subClassOf :Macrolide_Antibiotic .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Disease_Notification
:Disease_Notification rdf:type owl:Class ;
                      rdfs:subClassOf :Public_Health_Practice ;
                      :Synonyms """Infectious Disease Reportings
Disease Notifications
Exposure Notifications
Disease Reporting, Infectious
Reportings, Infectious Disease
Reporting, Infectious Disease
Infectious Disease Reporting
Notification, Exposure
Notifications, Exposure
Notifications, Disease
Notification, Disease
Exposure Notification
Disease Reportings, Infectious""" ;
                      :definition "Notification or reporting by a physician or other health care provider of the occurrence of specified contagious diseases such as tuberculosis and HIV infections to designated public health agencies. The United States system of reporting notifiable diseases evolved from the Quarantine Act of 1878, which authorized the US Public Health Service to collect morbidity data on cholera, smallpox, and yellow fever; each state in the US has its own list of notifiable diseases and depends largely on reporting by the individual health care provider." ;
                      :reference "http://purl.bioontology.org/ontology/MESH/D018563" ;
                      rdfs:label "Disease Notification" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Disinfection
:Disinfection rdf:type owl:Class ;
              rdfs:subClassOf :Sterilization ;
              :Synonyms "Disinfection" ;
              :definition "Rendering pathogens harmless through the use of heat, antiseptics, antibacterial agents, etc." ;
              :reference "http://purl.bioontology.org/ontology/MESH/D004203" ;
              rdfs:label "Disinfection" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Disseminated_Intravascular_Coagulation
:Disseminated_Intravascular_Coagulation rdf:type owl:Class ;
                                        rdfs:subClassOf :Complication ;
                                        :Synonyms """Disseminated intravascular coagulation
Consumptive Coagulopathy
Disseminated Intravascular Coagulation
Disseminated Intravascular Coagulation (DIC)
DIC""" ;
                                        :definition "A pathological process where the blood starts to coagulate throughout the whole body. This depletes the body of its platelets and coagulation factors, and there is an increased risk of hemorrhage." ;
                                        :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C2992" ;
                                        rdfs:label "Disseminated Intravascular Coagulation" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Disulfide_Linkage
:Disulfide_Linkage rdf:type owl:Class ;
                   rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13303> ;
                   :Synonyms """Disulfide Bond
Disulfide Linkage""" ;
                   :definition "A disulfide linkage is a covalent bond between 2 sulfide atoms from the thiol group of 2 cysteine residues (S-S). They occur both interstrand and intrastrand." ;
                   :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C14062" ;
                   rdfs:label "Disulfide Linkage" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Diuretic
:Diuretic rdf:type owl:Class ;
          rdfs:subClassOf :Pharmacologic_Substance ;
          :Synonyms """Diuretic
Diuretics
diuretic""" ;
          :definition "A class of agents that increases the production of urine by the kidney. Via various mechanism of actions, diuretics retain water in urine, thus provides a means of forced diuresis." ;
          :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C448" ;
          rdfs:label "Diuretic" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Divorced
:Divorced rdf:type owl:Class ;
          rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C25188> ;
          :Synonyms """Divorced Status
DIVORCED
Divorced""" ;
          :definition "Indicates a person whose marriage has been legally dissolved and has not remarried." ;
          :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C51776" ;
          rdfs:label "Divorced" .


