:Oxygen_Mask rdf:type owl:Class ;
             rdfs:subClassOf :Respiratory_Therapy ;
             :Synonyms "Oxygen mask (physical object)" ;
             :reference "http://purl.bioontology.org/ontology/SNOMEDCT/336602003" ;
             rdfs:label "Oxygen Mask" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Oxygen_Saturation
:Oxygen_Saturation rdf:type owl:Class ;
                   rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ;
                   :Synonyms """StO2	
Saturation of Peripheral Oxygen	
Oxygen Saturation""" ;
                   :definition "Extent to which HEMOGLOBIN is saturated with OXYGEN typically as measured in arterial blood. It can be measured by various methods (e.g., PULSE OXYMETER, blood gas analysis). A low blood oxygen saturation level indicates a condition called HYPOXEMIA." ;
                   :reference "http://purl.bioontology.org/ontology/MESH/D000089382" ;
                   rdfs:label "Oxygen Saturation" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Oxygenase
