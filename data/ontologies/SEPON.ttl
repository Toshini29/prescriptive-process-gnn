:Coagulation_Factor rdf:type owl:Class ;
                    rdfs:subClassOf :Ligand_Binding_Protein ;
                    :Synonyms """Blood Coagulation Factor
Coagulation Factor
Clotting Factor""" ;
                    :definition "Factors in the blood that are essential for blood coagulation. The absence or mutation of these factors can lead to hemophilia and blood clotting disorders." ;
                    :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16354" ;
                    rdfs:label "Coagulation Factor" .


