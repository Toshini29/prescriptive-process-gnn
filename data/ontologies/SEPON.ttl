                  :Synonyms "Transferase Gene" ;
                  :definition "Transferase Genes encode enzymes (Transferases) that transfer a group, such as a methyl group or a glycosyl group, from one compound (donor) to another (acceptor)." ;
                  :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C25870" ;
                  rdfs:label "Transferase Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Transforming_Growth_Factor-Beta_Family_Gene
:Transforming_Growth_Factor-Beta_Family_Gene rdf:type owl:Class ;
                                             rdfs:subClassOf :Growth_Factor_Gene ;
                                             :Synonyms "Transforming Growth Factor-Beta Family Gene" ;
                                             :definition "Expressed in a variety of tissues, Transforming Growth Factor-Beta Family Genes encode Transforming Growth Factor-Beta, an autocrine growth factor that can act synergistically with TGF-alpha in embryonic development, cellular differentiation, hormone secretion, and immune function. There are at least three forms of TGF-beta: TGF-beta 1, TGF-beta 2, and TGF-beta 1.2. The latter is a heterodimer of TGF-beta 1 and TGF-beta 2." ;
                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C21345" ;
                                             rdfs:label "Transforming Growth Factor-Beta Family Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Transforming_Growth_Factor-Beta_Superfamily
:Transforming_Growth_Factor-Beta_Superfamily rdf:type owl:Class ;
                                             rdfs:subClassOf :Growth_Factor ;
                                             :Synonyms """Transforming Growth Factor-Beta Superfamily
Tumor Growth Factor B
Transforming Growth Factor-Beta
Transforming Growth Factor Beta
Bone-Derived Transforming Growth Factor
Tumor Growth Factor Beta
Milk Growth Factor
TGF B
TGF Beta
TGF-B
TGF-Beta""" ;
                                             :definition "A family of structurally-related cytokines that bind to their cognate serine/threonine kinase receptors as homodimers or heterodimers linked by a single disulfide bond. These proteins play a role in embryonic development, hematopoiesis, tissue repair and extracellular matrix remodeling." ;
                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20455" ;
                                             rdfs:label "Transforming Growth Factor-Beta Superfamily" .


