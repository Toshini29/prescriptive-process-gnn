           :definition "Enzymes that oxidize substrates through transfer of oxygen from molecular oxygen." ;
           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C28459" ;
           rdfs:label "Oxygenase" .


