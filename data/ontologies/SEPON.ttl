             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C131282" ;
             rdfs:label "Fibroleukin" .


:Fibronectin :Synonyms """Large External Transformation-Sensitive Protein
Fibronectin
Cold-Insoluble Globulin
Large, External, Transformation-Sensitive Protein
LETS Protein
Fibronectin 1
CIG
FN
FN1
FNZ
LETS""" ;
             :definition "Fibronectin (2386 aa, ~263 kDa) is encoded by the human FN1 gene. This protein is involved in cell adhesion- and migration-dependent processes including embryogenesis, wound healing, blood coagulation, host defense, and metastasis." ;
             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16581" ;
             rdfs:label "Fibronectin" .


:Flucloxacillin :Synonyms """Floxacillin
FLUCLOXACILLIN
6-(3-(2-chloro-6-fluorophenyl)-5-methyl-4-isoxazolecarboxamido)-3,3-dimethyl-7-oxo-4-thia-1-azabicyclo(3.2.0)heptane-2-carboxylic Acid
3-(2-chloro-6-fluorophenyl)-5-methyl-4-isoxazolylpenicillin
Flucloxacillin
BRL 2039""" ;
                :definition "A narrow-spectrum, semisynthetic isoxazolyl penicillin with antibacterial activity. Floxacillin binds to and inactivates penicillin-binding proteins (PBPs) located on the inner membrane of the bacterial cell wall. Inactivation of PBPs interferes with the cross-linkage of peptidoglycan chains necessary for bacterial cell wall strength and rigidity. This interrupts bacterial cell wall synthesis and results in the weakening of the bacterial cell wall, eventually causing cell lysis." ;
                :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C80591" ;
                rdfs:label "Flucloxacillin" .


:Fluconazole :Synonyms """fluconazole
Fluconazole
alpha-(2,4-difluorophenyl)-alpha- (1,2,4-triazol-1-ylmethyl)-1,2, 4- triazole-1-ethanol
FLUCONAZOLE
Diflucan""" ;
             :definition "A synthetic triazole with antifungal activity. Fluconazole preferentially inhibits fungal cytochrome P-450 sterol C-14 alpha-demethylation, resulting in the accumulation of fungal 14 alpha-methyl sterols, the loss of normal fungal sterols, and fungistatic activity. Mammalian cell demethylation is much less sensitive to fluconazole inhibition." ;
             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C500" ;
             rdfs:label "Fluconazole" .


