                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C41443> ;
                                                            :Synonyms """Nervous Tissue
Human Nerve Tissue
Nerve Tissue""" ;
                                                            :definition "The tissue that generates and conducts electrical signals in the body. It contains the neurons." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13052" ;
                                                            rdfs:label "Nerve Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13102
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13102> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Prostatic Duct" ;
                                                            :definition "A small canal that receives prostatic secretions from the glandular tubules and discharges it through the prostatic portion of the urethra." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13102" ;
                                                            rdfs:label "Prostatic Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13104
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13104> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33414> ;
                                                            :Synonyms """Prostatic Stroma
Stroma of the Prostate Gland""" ;
                                                            :definition "The non-glandular tissue of the prostate gland, consisting of two major cell types, smooth muscle cells and fibroblasts. Stromal cells are key regulators of growth and differentiation in the prostate." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13104" ;
                                                            rdfs:label "Prostatic Stroma" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13170
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13170> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33952> ;
                                                            :Synonyms """Virchow-Hassall Body
Hassall's Body
Hassall's Corpuscle
Thymic Corpuscle
Hassall's Concentric Corpuscle""" ;
                                                            :definition "A small spherical body composed of keratinized squamous epithelial cells arranged in a concentric pattern in the medullary portion of the thymus." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13170" ;
                                                            rdfs:label "Hassall's Corpuscle" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13186
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13186> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13404> ;
                                                            :Synonyms """A-DNA
A-Form DNA""" ;
                                                            :definition "A-DNA is a shorter and wider helix than B-DNA. Most RNA and RNA-DNA duplex are in this form. While deep, narrow major groove is not easily accessible to proteins but wide, shallow minor groove is accessible to proteins but with lower information content than major groove. A-DNA is the favored conformation at low water concentrations. Base pairs are tilted to helix axis and displaced from axis and sugar pucker is C3'-endo (in RNA 2'-OH inhibits C2'-endo conformation). When examined from the top of the helix, there is a large hole in the middle, the sugar phosphate backbone is at the edge of the helix, and the bases are displaced towards the edge." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13186" ;
                                                            rdfs:label "A-DNA" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13190
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13190> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13236> ;
                                                            :Synonyms """AQUEOUS HUMOR
aqueous humor
aqueous humor of eyeball
Aqueous Humor
Aqueous Fluid
humor aquosus
EYE, AQUEOUS HUMOR
aqueous humour
Aqueous Humour""" ;
                                                            :definition "The watery fluid which is present in the anterior and posterior chambers of the eye." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13190" ;
                                                            rdfs:label "Aqueous Humor" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13192
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13192> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32875> ;
                                                            :Synonyms """BILE
Bile
Bile Fluid
Bile Juice
bile""" ;
                                                            :definition "Fluid composed of waste products, bile acids, salts, cholesterol, and electrolytes. It is secreted by the liver parenchyma and stored in the gallbladder." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13192" ;
                                                            rdfs:label "Bile" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13202
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13202> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13404> ;
                                                            :Synonyms """Chromosomal
CHROMOSOME
Chromosome
chromosome""" ;
                                                            :definition "A structure found in cells that is comprised of a strand of linearized double-stranded DNA plus proteins that package the DNA in a condensed coil form and regulate chromosomal function." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13202" ;
                                                            rdfs:label "Chromosome" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13203
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13203> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13202> ;
                                                            :Synonyms "Human Chromosome" ;
                                                            :definition "A structure found in the nucleus of human cells that is comprised of a strand of linearized double-stranded DNA plus proteins that package the DNA in a condensed coil form and regulate chromosomal function." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13203" ;
                                                            rdfs:label "Human Chromosome" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13228
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13228> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13298> ;
                                                            :Synonyms "Satellite DNA" ;
                                                            :definition "DNA that contains many tandem highly repetitive sequences, that have a base composition (and thus density) sufficiently different from that of normal DNA that it sediments as a distinct band in cesium chloride density gradients. Satellite DNA is located at very specific spots in the genome (on chromosomes 1, 9, 16 and the Y chromosome, the tiny short arms of chromosomes 13-15 and 21 and 22, and near the centromeres of chromosomes)." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13228" ;
                                                            rdfs:label "Satellite DNA" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132289
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132289> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C21007> ;
                                                             :Synonyms "Functional Disability" ;
                                                             :definition "An impairment that causes an individual to require assistance in order to perform an activity." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132289" ;
                                                             rdfs:label "Functional Disability" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13234
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13234> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13321> ;
                                                            :Synonyms """Gastrointestinal Tract, Feces
FECES
Fecal
Feces
STOOL
Stool
feces
stool""" ;
                                                            :definition "The material discharged from the bowel during defecation. It consists of undigested food, intestinal mucus, epithelial cells, and bacteria." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13234" ;
                                                            rdfs:label "Feces" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13236
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13236> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12219> ;
                                                            :Synonyms """Body Fluids or Substances
Body Fluids and Substances
Body Fluid or Substance
Fluid""" ;
                                                            :definition "Material produced by living organism; it can be a nessesary consituent of, or product of an organismal process." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13236" ;
                                                            rdfs:label "Body Fluid or Substance" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132461
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132461> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13356> ;
                                                             :Synonyms """CAPILLARY PLASMA
Capillary Plasma""" ;
                                                             :definition "Plasma that has been isolated from capillary blood." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132461" ;
                                                             rdfs:label "Capillary Plasma" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132462
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132462> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13356> ;
                                                             :Synonyms """VENOUS PLASMA
Venous Plasma""" ;
                                                             :definition "Plasma that has been isolated from venous blood." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132462" ;
                                                             rdfs:label "Venous Plasma" .


