                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13251" ;
                                                            rdfs:label "Long Terminal Repeat" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132510
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132510> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132507> ;
                                                             rdfs:label "Upper Jugular Lymph Node Group (Sublevels IIA and IIB)" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132511
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132511> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132507> ;
                                                             rdfs:label "Middle Jugular Lymph Node Group (Level III)" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132512
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132512> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132507> ;
                                                             rdfs:label "Lower Jugular Lymph Node Group (Level IV)" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132513
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132513> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132507> ;
                                                             rdfs:label "Posterior Triangle Lymph Node Group (Sublevels VA and VB)" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132514
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132514> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132507> ;
                                                             rdfs:label "Anterior Compartment Lymph Node Group (Level VI)" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132515
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132515> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C132507> ;
                                                             rdfs:label "Superior Mediastinal Lymph Node Group (Level VII)" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13252
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13252> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13236> ;
                                                            :Synonyms """Reticuloendothelial System, Lymph
lymphatic fluid
LYMPH
Lymph
lymph""" ;
                                                            :definition "A clear, transparent, sometimes faintly yellow and slightly opalescent fluid that is collected from the tissues throughout the body, flows in the lymphatic vessels (through the lymph nodes), and is eventually added to the venous blood circulation. Lymph consists of a clear liquid portion, varying numbers of white blood cells (chiefly lymphocytes), and a few red blood cells." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13252" ;
                                                            rdfs:label "Lymph" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13259
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13259> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13236> ;
                                                            :Synonyms """MUCUS
Mucus
mucus""" ;
                                                            :definition "The thick fluid secreted by the mucus glands in the aerodigestive tract and the vagina." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13259" ;
                                                            rdfs:label "Mucus" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13260
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13260> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms """Paramesonephric Duct
Mullerian Duct
Müllerian Duct""" ;
                                                            :definition "A pair of embryonic tubular structures that extend along the genital ridge and continue toward the cloaca, which in females will develop into the vagina, uterus, and fallopian tubes, and which will degenerate and be resorbed in males." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13260" ;
                                                            rdfs:label "Mullerian Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13270
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13270> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13321> ;
                                                            :Synonyms "Pancreatic Secretion" ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13270" ;
                                                            rdfs:label "Pancreatic Secretion" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13273
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13273> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13722> ;
                                                            :Synonyms """LUNG SURFACTANT
Surfactant, Lung
Lung Surfactant
Surfactant""" ;
                                                            :definition "Pulmonary surfactant lines the lung epithelium and lowers surface tension to prevent collapse at end-expiration. Deficiency of pulmonary surfactant results in respiratory distress syndrome (RDS) in premature infants. Lung surfactant is synthesized in alveolar type II cells, stored in lamellar bodies and secreted via exocytosis." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13273" ;
                                                            rdfs:label "Lung Surfactant" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13275
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13275> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C34062> ;
                                                            :Synonyms """Head and Neck, Saliva
SALIVA
Saliva
saliva""" ;
                                                            :definition "The watery fluid in the mouth made by the salivary glands. Saliva moistens food to help digestion and it helps protect the mouth against infections." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13275" ;
                                                            rdfs:label "Saliva" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13276
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13276> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13409> ;
                                                            :Synonyms """SEBUM
Sebum
sebum""" ;
                                                            :definition "A thick, oily substance produced by the sebaceous glands located in the dermis." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13276" ;
                                                            rdfs:label "Sebum" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13277
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13277> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13713> ;
                                                            :Synonyms """Human Semen (Sperm)
Seminal Plasma
SEMEN
Semen
semen""" ;
                                                            :definition "The thick, whitish secretion of the male reproductive organs. It is composed of spermatozoa in their nutrient plasma, secretions from the prostate, seminal vesicles, and various other glands, epithelial cells, and minor constituents." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13277" ;
                                                            rdfs:label "Semen" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13278
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13278> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13722> ;
                                                            :Synonyms """SPUTUM
Sputum
sputum""" ;
                                                            :definition "Material containing mucus, cellular debris, microorganisms and sometimes blood or pus. It is ejected through the mouth from the lungs, bronchi, and trachea." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13278" ;
                                                            rdfs:label "Sputum" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13280
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13280> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13409> ;
                                                            :Synonyms """PERSPIRATION
Perspiration
SWEAT
Sweat
Sweats""" ;
                                                            :definition "The liquid secreted by the sweat glands, having a salty taste and a pH that varies from 4.5 to 7.5. Sweat produced by the eccrine sweat glands is clear with a faint characteristic odor, and contains water, sodium chloride, and traces of albumin, urea, and other compounds. Its composition varies with many factors, e.g., fluid intake, external temperature and humidity, and some hormonal activity. Sweat produced by the larger, deeper, apocrine sweat glands of the axillae contains, in addition, organic material which on bacterial decomposition produces an offensive odor." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13280" ;
                                                            rdfs:label "Sweat" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13283
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13283> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13236> ;
                                                            :Synonyms """Urinary System, Urine
URINE
Urine
urine""" ;
                                                            :definition "The fluid that is excreted by the kidneys. It is stored in the bladder and discharged through the urethra." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13283" ;
                                                            rdfs:label "Urine" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13287
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13287> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13404> ;
                                                            :Synonyms """Z-DNA
zDNA""" ;
                                                            :definition "Z-DNA can be obtained for certain sequences such as CGCGCG by increasing the salt concentration of the solution containing the sample to 4 molar NaCl. Z-DNA is left-handed and the thinnest & tallest with a diameter of about 18 Angstrom. The sugar pucker is both C(3')-endo and C(2')-endo. In Z-DNA, the Watson-Crick base pairs are perpendicular to the helix axis. When examined from the top of the helix, bases are present throughout the matrix of the helix with no exclusive domains for either the bases or the backbone. At times the sugar phosphate backbone travels very close to the center of the helix, and the bases to the very edge of the helix." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13287" ;
                                                            rdfs:label "Z-DNA" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13292
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13292> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C63552> ;
                                                            :Synonyms """Open Reading Frame
ORF""" ;
                                                            :definition "A sequence of nucleotides in that contains no termination codons and so can potentially translate as a polypeptide chain." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13292" ;
                                                            rdfs:label "Open Reading Frame" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13298
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13298> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13299> ;
                                                            :Synonyms """Repeated Sequences
Repetitive Sequence
Repetitive Element
Repeated Sequence""" ;
                                                            :definition "Nucleotide sequences present in multiple copies in the genome. There are several types of repeated sequences. Interspersed (or dispersed) DNA repeats (Interspersed Repetitive Sequences) are copies of transposable elements interspersed throughout the genome. Flanking (or terminal) repeats (Terminal Repeat Sequences) are sequences that are repeated on both ends of a sequence, for example, the long terminal repeats (LTRs) on retroviruses. Direct terminal repeats are in the same direction and inverted terminal repeats are opposite to each other in direction. Tandem repeats (Tandem Repeat Sequences) are repeated copies which lie adjacent to each other. These can also be direct or inverted. The ribosomal RNA and transfer RNA genes belong to the class of middle repetitive DNA." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13298" ;
                                                            rdfs:label "Repetitive Sequence" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13299
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13299> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C45374> ;
                                                            :Synonyms """DNA Sequence
Sequence
Sequences""" ;
                                                            :definition "The sequence of nucleotide residues along a DNA chain." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13299" ;
                                                            rdfs:label "DNA Sequence" .


