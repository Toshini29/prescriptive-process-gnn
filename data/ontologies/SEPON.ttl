                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C126083" ;
                                                             rdfs:label "Basal Metabolic Rate" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12664
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12664> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C25444> ;
                                                            :Synonyms """abdominopelvis
Abdomen, total
BODY CAVITY, ABDOMINAL
Abdomen, NOS
ABDOMINAL CAVITY
abdominopelvic region
Abdominal Cavity
Abdomen
abdomen""" ;
                                                            :definition "The cavity located between the lungs and pelvis. It contains the lower esophagus, stomach, pancreas, intestines, liver, gallbladder and spleen." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12664" ;
                                                            rdfs:label "Abdomen" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12666
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12666> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12704> ;
                                                            :Synonyms """Adrenal gland
ADRENAL GLAND
Adrenal Glands
glandula suprarenalis
adrenal gland
suprarenal gland
Adrenal gland, NOS
Adrenal Gland
GLAND, ADRENAL
Adrenal structure (body structure)
glandula adrenalis
Adrenal
Adrenals""" ;
                                                            :definition "A flattened, roughly triangular body resting upon the upper end of each kidney; it is one of the ductless glands furnishing internal secretions (epinephrine and norepinephrine from the medulla and steroid hormones from the cortex)." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12666" ;
                                                            rdfs:label "Adrenal Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12675
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12675> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712> ;
                                                            :Synonyms """Bartholin Gland
Bartholin's Gland""" ;
                                                            :definition "The two mucous secreting glands on either side of the vaginal opening." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12675" ;
                                                            rdfs:label "Bartholin Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12678
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12678> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """biliary system
BILIARY TRACT
biliary tract
Tract, Biliary
Biliary tract, NOS
Biliary Tract
Biliary System
Bile Tract""" ;
                                                            :definition "The system that transports bile from the hepatocytes in the liver to the small intestine. It is comprised of the intrahepatic bile ducts, hepatic ducts, common bile duct, cystic duct, and the gallbladder." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12678" ;
                                                            rdfs:label "Biliary Tract" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12686
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12686> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12919> ;
                                                            :Synonyms """CARDIOVASCULAR SYSTEM
circulatory system
Vascular, Heart
Body System, Cardiovascular
Cardiovascular
Cardiovascular System
Cardiovascular Organ System
Circulatory System
Organ System, Cardiovascular
Cardiovascular Body System""" ;
                                                            :definition "Relating to the heart and the blood vessels or the circulation." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12686" ;
                                                            rdfs:label "Cardiovascular System" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12692
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12692> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13236> ;
                                                            :Synonyms """Cerebrospinal fluid
FLUID, CEREBROSPINAL
Cerebrospinal Fluid
CEREBROSPINAL FLUID
cerebral spinal fluid
Cerebral Spinal Fluid
cerebrospinal fluid
Cerebral spinal fluid
CSF""" ;
                                                            :definition "The fluid that is contained within the brain ventricles, the subarachnoid space and the central canal of the spinal cord." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12692" ;
                                                            rdfs:label "Cerebrospinal Fluid" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12704
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12704> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13319> ;
                                                            :Synonyms """Endocrine gland, NOS
Endocrine Organs
endocrine gland
Endocrine Gland
ductless gland
glandula endocrina""" ;
                                                            :definition "Ductless glands that secrete substances which are released directly into the circulation and which influence metabolism and other body functions." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12704" ;
                                                            rdfs:label "Endocrine Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12705
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12705> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12919> ;
                                                            :Synonyms """Metabolic/Endocrine Body System
endocrine system
Organ System, Endocrine/Metabolic
Body System, Endocrine/Metabolic
Endocrine/Metabolic Body System
Hormonal System
Endocrine/Metabolic Organ System
Endocrine System
Endocrine""" ;
                                                            :definition "Collective designation for those tissues capable of secreting hormones." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12705" ;
                                                            rdfs:label "Endocrine System" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13319> ;
                                                            :Synonyms """Apocrine Gland
apocrine gland
Exocrine Gland
Apocrine""" ;
                                                            :definition "A gland from which secretions reach a free surface of the body by ducts." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712" ;
                                                            rdfs:label "Exocrine Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12725
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12725> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """GONAD
Gonad
Gonadal
Gonads
gonad""" ;
                                                            :definition "A reproductive system organ that produces and releases either sperm (testis) or eggs (ovary)." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12725" ;
                                                            rdfs:label "Gonad" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12727
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12727> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """vertebrate heart
chambered heart
Heart structure (body structure)
Cardiac
HEART
Heart
heart""" ;
                                                            :definition "A hollow organ located slightly to the left of the middle portion of the chest. It is composed of muscle and it is divided by a septum into two sides: the right side which receives de-oxygenated blood from the body and the left side which sends newly oxygenated blood to the body. Each side is composed of two chambers: the atrium (receiving blood) and ventricle (ejecting blood)." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12727" ;
                                                            rdfs:label "Heart" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12735
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12735> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12919> ;
                                                            :Synonyms """body system, allergic/immunologic
allergic/immunologic organ system
organ system, allergic/immunologic
immune system
immunologic/allergic organ system
allergic/immunologic body system
Immune System""" ;
                                                            :definition "The complex group of organs like thymus, spleen, tonsils, lymphatic system, hematopoetic system and cells like lymphocytes, granulocytes, monocytes and macrophages that defends the body against infection or disease. It consists of a complex interrelated cellular, molecular and genetic component." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12735" ;
                                                            rdfs:label "Immune System" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12736
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12736> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Intestinal tract, NOS
Intestinal structure (body structure)
Bowel
INTESTINE
Intestine
Intestines
bowel
intestine""" ;
                                                            :definition "The portion of the gastrointestinal tract between the stomach and the anus. It includes the small intestine and large intestine." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12736" ;
                                                            rdfs:label "Intestine" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12739
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12739> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33461> ;
                                                            :Synonyms """KIDNEY, CORTEX
Cortical Portion of Kidney
Renal Cortex
Structure of cortex of kidney (body structure)
Cortical Portion of the Kidney
Cortical""" ;
                                                            :definition "The outer part of the renal parenchyma beneath the renal capsule. It contains glomeruli and tubules." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12739" ;
                                                            rdfs:label "Renal Cortex" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12740
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12740> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33461> ;
                                                            :Synonyms """Medullary Portion of the Kidney
Medullary Portion of Kidney
Renal Medulla
KIDNEY, MEDULLA""" ;
                                                            :definition "The inner part of the renal parenchyma. It consists mostly of collecting tubules and is organized in sections called pyramids." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12740" ;
                                                            rdfs:label "Renal Medulla" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12745
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12745> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Lymph Node, NOS
Structure of lymph node (body structure)
Lymph Gland
Lymph Node(s)
Lymph node, NOS
Lymphatic Gland
Lymph nodes
lymph gland
Reticuloendothelial System, Lymph Node
Lymph Nodes
LYMPH NODE
Lymph Node
lymph node""" ;
                                                            :definition "A bean-shaped organ surrounded by a connective tissue capsule. It is part of the lymphatic system and is found throughout the body. It is composed predominantly of lymphocytes and its main function is immune protection." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12745" ;
                                                            rdfs:label "Lymph Node" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12754
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12754> rdf:type owl:Class ;
