                            rdfs:subClassOf :Anticoagulant_Agent ;
                            :Synonyms "Direct Factor Xa Inhibitor" ;
                            :definition "Any agent that binds to and inactivates factor Xa, with anticoagulant activity." ;
                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C173067" ;
                            rdfs:label "Direct Factor Xa Inhibitor" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Direct_Thrombin_Inhibitor
