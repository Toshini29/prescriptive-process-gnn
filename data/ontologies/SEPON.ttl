###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Liver_Function_Test
:Liver_Function_Test rdf:type owl:Class ;
                     rdfs:subClassOf :Chemistry_Test ;
                     :Synonyms """liver function test
Liver Function Test
LFT""" ;
                     :definition "The quantitative measurement of liver enzymes in the blood, which is useful in assessing the functional state of a patient's liver. Liver function tests include the measurement of albumin, alanine transaminase, aspartate transaminase, alkaline phosphatase, bilirubin, and gamma glutamyl transferase." ;
                     :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C74954" ;
                     rdfs:label "Liver Function Test" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Loop_Diuretic
:Loop_Diuretic rdf:type owl:Class ;
               rdfs:subClassOf :Diuretic ;
               :Synonyms "Loop Diuretic" ;
               :definition "Any agent belonging to the class of loop diuretics. Loop diuretics block and inhibit the function of the sodium-potassium-chloride (Na+, K+, Cl-) cotransporter system in the thick ascending limb of the loop of Henle, thereby inhibiting the reabsorption of sodium, potassium, and chloride ions. This leads to an increase in the excretion of sodium, potassium, chloride, calcium, magnesium, ammonium and water." ;
               :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C49184" ;
               rdfs:label "Loop Diuretic" .


