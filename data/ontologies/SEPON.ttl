                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32589" ;
                                                            rdfs:label "Female Genital System Fluid or Secretion" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32591
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32591> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12417> ;
                                                            :Synonyms "Female Urethra" ;
                                                            :definition "The 1.5 inch long tube carrying urine from the bladder to the outside of the body exiting between the clitoris and vagina." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32591" ;
                                                            rdfs:label "Female Urethra" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32598
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32598> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13236> ;
                                                            :Synonyms "Fibrin" ;
                                                            :definition "A glycosylated elastic protein produced by the cleavage of fibrinogen by the protease thrombin during blood coagulation." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32598" ;
                                                            rdfs:label "Fibrin" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32643
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32643> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712> ;
                                                            :Synonyms """Fundic Gland
Fundus Gland
Gastric Gland""" ;
                                                            :definition "The tubular glands in the mucosa of the gastric fundus that can secrete mucous, hydrochloric acid, pepsinogen, or any of the digestive hormones." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32643" ;
                                                            rdfs:label "Fundic Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32657
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32657> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32664> ;
                                                            :Synonyms """Gastric Muscularis Externa
Gastric Muscular Coat""" ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32657" ;
                                                            rdfs:label "Gastric Muscular Coat" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32661
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32661> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13321> ;
                                                            :Synonyms """Gastric Secretion
Gastric Juice""" ;
                                                            :definition "The digestive secretions of the gastric glands in the stomach, consisting mainly of pepsin, hydrochloric acid, rennin, and mucin." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32661" ;
                                                            rdfs:label "Gastric Secretion" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32663
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32663> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32664> ;
                                                            :Synonyms "Gastric Submucosa" ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32663" ;
                                                            rdfs:label "Gastric Submucosa" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32664
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32664> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12801> ;
                                                            :Synonyms "Gastric Tissue" ;
                                                            :definition "The tissue of the stomach. It is composed of a fibrous outer layer bounded by smooth muscle, the submucosa, and the mucosa. The mucosa of the stomach consists of secretory cells that produce hydrochloric acid and gastric enzymes." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32664" ;
                                                            rdfs:label "Gastric Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32695
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32695> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13052> ;
                                                            :Synonyms "Gray Matter" ;
                                                            :definition "The nerve tissue composed of nerve cell bodies, unmyelinated nerve fibers and supportive tissue found in the brain and spinal cord. It is differentiated from the white matter by color of the tissues and the presence of more myelinated nerve cells in the white matter." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32695" ;
                                                            rdfs:label "Gray Matter" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32732
