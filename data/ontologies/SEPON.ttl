                                                             :Synonyms """Red Blood Cells, Deglycerolized
Deglycerolized Red Blood Cells
Red Blood Cells Deglycerolized""" ;
                                                             :definition "Red blood cells washed free of the glycerol in which they have been stored." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133351" ;
                                                             rdfs:label "Deglycerolized Red Blood Cells" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133352
