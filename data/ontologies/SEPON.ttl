:Reproductive_History rdf:type owl:Class ;
                      rdfs:subClassOf :Personal_Medical_History ;
                      :Synonyms """Reproductive Issues
Reproductive History
Reproductive Factors""" ;
                      :definition "An account of all reproductive events and problems a person has experienced. An important aggregate factor in epidemiological studies of women's health. The concept usually includes the number and timing of pregnancies and their outcomes, the incidence of breast feeding, and may include age of menarche and menopause, regularity of menstruation, fertility, gynecological or obstetric problems, or contraceptive usage." ;
                      :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17655" ;
                      rdfs:label "Reproductive History" .


