###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Quarantine
:Quarantine rdf:type owl:Class ;
            rdfs:subClassOf :Public_Health_Practice ;
            :Synonyms """Health Lockdown
Health Travel Restrictions
Border Travel Restrictions, Health-Related
Lockdown, Health
Self-Quarantine
Stay at Home Orders
Travel Restriction, Health
Self Quarantine
Health Related Border Travel Restrictions
Border Closing, Health Related
Health-Related Travel Restriction
Health Related Travel Restrictions
Cordon Sanitaire
Travel Restrictions, Health-Related
Health Related Travel Restriction
Travel Restrictions, Health Related
Health-Related Travel Restrictions
Border Closing, Health-Related
Health-Related Border Closings
Health-Related Border Closing
Travel Restrictions, Health
Health Travel Restriction
Quarantines
Border Closings, Health-Related
Health Lockdowns
Health-Related Border Travel Restrictions
Travel Restriction, Health-Related
Border Travel Restrictions, Health Related""" ;
            :definition "Limited freedom of movement of individuals to reduce the risk of spread of communicable disease by those who have been exposed to infectious or communicable disease in order to prevent its spread; a period of detention of vessels, vehicles, or travelers coming from infected or suspected places; and detention or isolation on account of suspected contagion. It includes government regulations on travel restrictions, border security measures to mitigate spread of a contagion and the detention of animals at frontiers or ports of entrance for the prevention of infectious disease." ;
            :reference "http://purl.bioontology.org/ontology/MESH/D011790" ;
            rdfs:label "Quarantine" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Quick_Sequential_Organ_Failure_Assessment
:Quick_Sequential_Organ_Failure_Assessment rdf:type owl:Class ;
                                           rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ,
                                                           :Adult_Sepsis_Prognostic_Biomarker ,
                                                           :Diagnostic_Criteria ;
                                           :Synonyms """Quick Sequential Organ Failure Assessment
qSOFA""" ;
                                           :definition "A diagnostic criteria for sepsis." ;
                                           :reference "Singer M, Deutschman CS, Seymour CW, Shankar-Hari M, Annane D, Bauer M, Bellomo R, Bernard GR, Chiche JD, Coopersmith CM, Hotchkiss RS, Levy MM, Marshall JC, Martin GS, Opal SM, Rubenfeld GD, van der Poll T, Vincent JL, Angus DC. The Third International Consensus Definitions for Sepsis and Septic Shock (Sepsis-3). JAMA. 2016 Feb 23;315(8):801-10. doi: 10.1001/jama.2016.0287. PMID: 26903338; PMCID: PMC4968574." ;
                                           rdfs:label "Quick Sequential Organ Failure Assessment" .


