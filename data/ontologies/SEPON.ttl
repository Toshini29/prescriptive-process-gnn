<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32297> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32589> ;
                                                            :Synonyms """Cervical Gland Secretion
Cervical Mucus""" ;
                                                            :definition "The mucous produced by the glands in the cervix which is composed mainly of water but also contains electrolytes, amino acids, glucose, proteins and other trace elements (e.g. Mn, Fe, Cu, Zn, and Se)." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32297" ;
                                                            rdfs:label "Cervical Gland Secretion" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32335
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32335> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Cochlear Duct" ;
                                                            :definition "A membranous tube containing endolymph within the cochlea between the scala vestibuli and the scala tympani." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32335" ;
                                                            rdfs:label "Cochlear Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32386
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32386> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13052> ;
                                                            :Synonyms "Cortical Cell Layer" ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32386" ;
                                                            rdfs:label "Cortical Cell Layer" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32484
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32484> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Duct of the Epididymis" ;
                                                            :definition "A convoluted tube connecting the efferent ductules of the testicle to the vas deferens." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32484" ;
                                                            rdfs:label "Duct of the Epididymis" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32485
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32485> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Duct of Gartner" ;
                                                            :definition "An embryonic remnant of the mesonephric duct in females that runs parallel to the uterus, cervix and vagina." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32485" ;
                                                            rdfs:label "Duct of Gartner" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32487
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32487> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms """Ductus Pancreaticus Accessorius
Accessory Pancreatic Duct
Ductus Santorini""" ;
                                                            :definition "An accessory pancreatic duct with two branches, one of which opens directly to the duodenum at the minor duodenal papilla while the other connects to the pancreatic duct." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32487" ;
                                                            rdfs:label "Ductus Santorini" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32490
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32490> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33712> ;
                                                            :Synonyms """eccrine gland
Eccrine Sweat Gland""" ;
                                                            :definition "An unbranched, coiled, tubular gland not associated with the hair follicle that promotes cooling by evaporation of its secretion. It is innervated by cholinergic nerve fibers." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32490" ;
                                                            rdfs:label "Eccrine Sweat Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32492
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32492> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms """Efferent Ductule
Efferent Duct
DUCT, EFFERENT""" ;
                                                            :definition "One of 12 to 14 small seminal ducts leading from the testis to the head of the epididymis." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32492" ;
                                                            rdfs:label "Efferent Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32493
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32493> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Ejaculatory Duct" ;
                                                            :definition "Bilateral tubes formed by the joining of the vas deferens and the excretory duct of the seminal vesicle which merge into the urethra after passing through the prostate." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32493" ;
                                                            rdfs:label "Ejaculatory Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32508
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32508> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32510> ;
                                                            :Synonyms "Endocrine Ovary" ;
                                                            :definition "The part of the ovary that produces hormones, mainly estrogen and progesterone, though small amounts of androgens and other protein hormones are also produced." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32508" ;
                                                            rdfs:label "Endocrine Ovary" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32510
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32510> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12704> ;
                                                            :Synonyms "Endocrine Sex Organ" ;
                                                            :definition "The tissue responsible for generating and secreting hormones involved in reproduction. In males, testosterone is produced and secreted from the testes while the female ovaries produce and secrete estrogens and progestrones." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32510" ;
                                                            rdfs:label "Endocrine Sex Organ" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32511
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32511> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32510> ;
                                                            :Synonyms "Endocrine Testis" ;
                                                            :definition "The part of the testis that produces testosterone." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32511" ;
                                                            rdfs:label "Endocrine Testis" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32513
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32513> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33231> ;
                                                            :Synonyms "Endolymph" ;
                                                            :definition "The bodily fluid that fills the membranous labyrinth of the inner ear." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32513" ;
                                                            rdfs:label "Endolymph" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32514
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32514> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C25444> ;
                                                            :Synonyms """ENDOMETRIAL CAVITY
Endometrial Cavity""" ;
                                                            :definition "A space inside the uterus lined by a layer of mucus membranes called the endometrium." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32514" ;
                                                            rdfs:label "Endometrial Cavity" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32536
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32536> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712> ;
                                                            :Synonyms "Esophageal Gland" ;
                                                            :definition "The small, compound, unbranched exocrine glands varying in number that are located within the submucosa of the esophagus." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32536" ;
                                                            rdfs:label "Esophageal Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32543
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32543> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12801> ;
                                                            :Synonyms "Esophageal Tissue" ;
                                                            :definition "The tissue of the esophageal wall. It is composed of mucosa, a muscular coat, and a serosal surface." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32543" ;
                                                            rdfs:label "Esophageal Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32546
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32546> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712> ;
                                                            :Synonyms """Exocrine Pancreas
PANCREAS, EXOCRINE""" ;
                                                            :definition "An enzyme producing region of the pancreatic tissue containing the pancreatic acini and exocrine intralobular ducts which collectively secrete the digestive enzymes into the main pancreatic duct to drain into the duodenal part of the small intestine." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32546" ;
                                                            rdfs:label "Exocrine Pancreas" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32586
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32586> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13052> ;
                                                            :Synonyms "Fascicle" ;
                                                            :definition "A small bundle of nerve fibers that is more or less associated functionally." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32586" ;
                                                            rdfs:label "Fascicle" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32589
