       rdfs:subClassOf :Ventilation_or_Perfusion_Signs_and_Symptoms ;
       :Synonyms """Circulatory Collapse
Shock""" ;
       :definition "A life-threatening condition that requires immediate medical intervention. It is characterized by reduced blood flow that may result in damage of multiple organs. Types of shock include cardiogenic, hemorrhagic, septic, anaphylactic, and traumatic shock." ;
       :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C35016" ;
       rdfs:label "Shock" .


