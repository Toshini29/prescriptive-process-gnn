                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C94552> ;
                                                             :Synonyms """ALVEOLAR AIR
Alveolar Air""" ;
                                                             :definition "The gas located in the alveolus of the lungs, which takes part in gas exchange with the blood in the pulmonary capillaries." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C150891" ;
                                                             rdfs:label "Alveolar Air" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C150892
