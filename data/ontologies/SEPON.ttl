                                     :definition "Signs and symptoms associated with disturbances within the digestive system, which includes the stomach, intestines and all associated organs that aid in digestion." ;
                                     :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C3368" ;
                                     rdfs:label "Digestive System Signs and Symptoms" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Diiodotyrosine
:Diiodotyrosine rdf:type owl:Class ;
                rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ;
                :Synonyms """Iodogorgoic Acid
Tyrosine, 3,5-diiodo-
Acid, Iodogorgoic""" ;
                :definition "A product from the iodination of MONOIODOTYROSINE. In the biosynthesis of thyroid hormones, diiodotyrosine residues are coupled with other monoiodotyrosine or diiodotyrosine residues to form T4 or T3 thyroid hormones (THYROXINE and TRIIODOTHYRONINE)." ;
                :reference "http://purl.bioontology.org/ontology/MESH/D004105" ;
                rdfs:label "Diiodotyrosine" .


