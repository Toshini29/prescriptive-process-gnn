                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12409" ;
                                                            rdfs:label "Penis" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12410
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12410> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712> ;
                                                            :Synonyms """Prostatic structure (body structure)
GLAND, PROSTATE
Prostate gland
prostate gland
male prostate
PROSTATE GLAND
Genital System, Male, Prostate
Prostate Gland
Prostatic Gland
Prostate
prostate""" ;
                                                            :definition "The walnut shaped accessory sex gland of the male reproductive system. It is located in the pelvis just below the bladder, surrounding the prostatic part of the urethra. The prostate gland secretes a fluid which is part of the semen." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12410" ;
                                                            rdfs:label "Prostate Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12412
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12412> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12725> ;
                                                            :Synonyms """Genital System, Male, Testis
gonad of male reproductive system
gonad of male genitalia
Testis, NOS
Testis structure (body structure)
TESTIS
Testes
Testicle
Testicles
Testis
male gonad
testicle
testis""" ;
                                                            :definition "Either of the paired male reproductive glands that produce the male germ cells and the male hormones." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12412" ;
                                                            rdfs:label "Testis" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12414
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12414> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """URINARY BLADDER
Urinary Bladder
vesica urinaria
urinary bladder
Urinary bladder structure (body structure)
Urinary System, Bladder
Bladder, NOS
BLADDER
Bladder
bladder""" ;
                                                            :definition "The distensible sac-like organ that functions as a reservoir of urine, collecting from the kidneys and eliminating via the urethra." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12414" ;
                                                            rdfs:label "Bladder" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12415
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12415> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Kidney, NOS
Kidney structure (body structure)
Urinary System, Kidney
KIDNEY
Kidney
Kidneys
kidney""" ;
                                                            :definition "One of the two bean-shaped organs located on each side of the spine in the retroperitoneum. The right kidney is located below the liver and the left kidney below the diaphragm. The kidneys filter and secrete metabolic products and minerals from the blood, thus maintaining homeostasis. On the superior pole of each kidney there is an adrenal gland. Each kidney and adrenal gland is surrounded by fat." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12415" ;
                                                            rdfs:label "Kidney" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12416
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12416> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Ureteric structure (body structure)
URETER
Ureter
ureter""" ;
                                                            :definition "The thick-walled tube that carries urine from each kidney to the bladder." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12416" ;
                                                            rdfs:label "Ureter" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12417
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12417> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Urethral structure (body structure)
URETHRA
Urethra
urethra""" ;
                                                            :definition "The tube carrying urine from the bladder to outside of the body." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12417" ;
                                                            rdfs:label "Urethra" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12421
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12421> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C25444> ;
