                       rdfs:subClassOf :Pain_Assessment ;
                       :Synonyms """Behavioral Rating Scale
Behavior Rating Scale
BPS
Behavioral Pain Scale""" ;
                       :definition "A range of values designed to quantify the qualitative responses of an individual to a set of challenges." ;
                       :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C81235" ;
