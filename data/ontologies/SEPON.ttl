                                                                             <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C26548> ;
                                                            :Synonyms "Abnormal Cell" ;
                                                            :definition "An abnormal human cell type which can occur in either disease states or disease models." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12913" ;
                                                            rdfs:label "Abnormal Cell" .


