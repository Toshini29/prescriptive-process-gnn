                                 :Synonyms """Viral Reverse Transcriptase Inhibitor
Reverse Transcriptase Inhibitor""" ;
                                 :definition "Any substance that inhibits the activity of viral reverse transcriptase, an RNA-dependent DNA polymerase that transcribes viral RNA into DNA during virus replication." ;
                                 :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C1589" ;
                                 rdfs:label "Reverse Transcriptase Inhibitor" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Ribavirin
:Ribavirin rdf:type owl:Class ;
           rdfs:subClassOf :Antiviral_Agent ;
           :Synonyms """1-Beta-D-ribofuranosyl-1,2,4-triazolo-3-carboxamide
1-Beta-D-ribofuranosyl-1H-1,2,4-triazole-3-carboxamide
1-.beta.-D-Ribofuranosyl-1H-1,2, 4-triazole-3-carboxamide
Copegus
ICN 1229
ICN-1229
RIBA
RIBAVIRIN
RTCA
Rebetol
Ribavirin
Viramide
Virazid
Virazole
ribavirin""" ;
           :definition "A synthetic nucleoside analog of ribofuranose with activity against hepatitis C virus and other RNA viruses. Ribavirin is incorporated into viral RNA, thereby inhibiting viral RNA synthesis, inducing viral genome mutations, and inhibiting normal viral replication." ;
           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C807" ;
           rdfs:label "Ribavirin" .


