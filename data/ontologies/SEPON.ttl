:Mandatory_Testing rdf:type owl:Class ;
                   rdfs:subClassOf :Public_Health_Practice ;
                   :Synonyms """Screening, Mandatory
Testing, Mandatory
Mandatory Screening""" ;
                   :definition "Testing or screening required by federal, state, or local law or other agencies for the diagnosis of specified conditions. It is usually limited to specific populations such as categories of health care providers, members of the military, and prisoners or to specific situations such as premarital examinations or donor screening." ;
                   :reference "http://purl.bioontology.org/ontology/MESH/D018580" ;
                   rdfs:label "Mandatory Testing" .


