                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33775" ;
                                                            rdfs:label "Thymus Medulla" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33785
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33785> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12801> ;
                                                            :Synonyms "Thyroid Gland Tissue" ;
                                                            :definition "The tissue that forms the thyroid gland. Its main component is the thyroid follicle." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33785" ;
                                                            rdfs:label "Thyroid Gland Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33803
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33803> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33414> ;
                                                            :Synonyms """Transitional Zone of the Prostatic Parenchyma
TZ""" ;
                                                            :definition "The zone of the prostatic parenchyma that surrounds the proximal urethra." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33803" ;
                                                            rdfs:label "Transitional Zone of the Prostatic Parenchyma" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33845
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33845> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Utriculosaccular Duct" ;
                                                            :definition "A channel located in the membranous labyrinth of the inner ear that connects the saccule to both the utricle and to the endolymphatic duct." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33845" ;
                                                            rdfs:label "Utriculosaccular Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33892
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33892> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13052> ;
                                                            :Synonyms """White Matter
WHITE MATTER TISSUE""" ;
                                                            :definition "The nerve tissue forming the bulk of the deep parts of the brain and the superficial parts of the spinal cord. It is composed of nerve cell processes, i.e. extensions (axons), which connect various grey matter areas of the brain to each other and carry nerve impulses to and from the nerve cell bodies within the central nervous system (neurons). Cerebral and spinal white matter does not contain dendrites. White matter is distinguished in that it is composed of axonal nerve fibers covered by a myelin sheath." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33892" ;
                                                            rdfs:label "White Matter" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33904
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33904> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12219> ;
                                                            :Synonyms """Other Anatomic Concept
