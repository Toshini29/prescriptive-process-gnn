:Thrombopoietin rdf:type owl:Class ;
                rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ,
                                :Colony_Stimulating_Factor .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Thrombospondin
:Thrombospondin rdf:type owl:Class ;
                rdfs:subClassOf :Regulatory_Protein ;
                :Synonyms """Thrombospondin
THBS
TSP""" ;
                :definition "A glycoprotein that is incorporated into cells, including blood platelets (thrombocytes) from which they are named. Five distinct forms have been identified, and they play roles in a variety of processes such as: blood coagulation, cell adhesion, platelet aggregation, cell proliferation, angiogenesis, tumor metastasis, and tissue repair." ;
                :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17339" ;
                rdfs:label "Thrombospondin" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Thrombospondin-1
:Thrombospondin-1 rdf:type owl:Class ;
                  rdfs:subClassOf :Paediatric_Sepsis_Prognostic_Biomarker ,
                                  :Thrombospondin .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Thrombotic_Disorder
:Thrombotic_Disorder rdf:type owl:Class ;
                     rdfs:subClassOf :Coagulation_Disorder ;
                     :Synonyms "Thrombotic Disorder" ;
                     :definition "A disorder in which there is pathological development of blood clots within the cardiovascular system." ;
                     :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C180553" ;
                     rdfs:label "Thrombotic Disorder" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Thrombotic_Microangiopathy
:Thrombotic_Microangiopathy rdf:type owl:Class ;
                            rdfs:subClassOf :Thrombotic_Disorder ;
                            :Synonyms """Thrombotic Microangiopathy
Thrombotic microangiopathy
TMA""" ;
                            :definition "A microvascular coagulopathy that may result from systemic vascular endothelial injury triggering the development of a procoagulant state, activation of the complement cascade, and microthrombi formation. Signs may include hemolytic anemia, thrombocytopenia, hypertension and renal dysfunction." ;
                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C62605" ;
                            rdfs:label "Thrombotic Microangiopathy" .


