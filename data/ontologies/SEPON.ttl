###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#GTPase
:GTPase rdf:type owl:Class ;
        rdfs:subClassOf :Hydrolase ;
        :Synonyms """Guanosinetriphosphatase
GTPase""" ;
        :definition "Proteins that hydrolyze guanine triphosphate to yield guanine diphosphate. This is a class of proteins that belongs to a family of high energy phosphate hydrolases. Members of this family play major roles in biological signal transduction pathways." ;
        :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16650" ;
        rdfs:label "GTPase" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#GTPase_Gene
:GTPase_Gene rdf:type owl:Class ;
             rdfs:subClassOf :Hydrolase_Gene ;
             :Synonyms "GTPase Gene" ;
             :definition "Genes (superfamily) that encode GTP hydrolyzing enzymes, which cycle between the GDP-bound inactive state and the GTP-bound active state acting as intracellular switches in various cellular pathways, such as signal transduction." ;
             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C25805" ;
             rdfs:label "GTPase Gene" .


