:North_American rdf:type owl:Class ;
                rdfs:subClassOf :Race ;
                :Synonyms "North American" ;
                :definition "Denotes a person of European, Middle Eastern, or North African ancestral origins whose family settled in a North American country such as the United States of America or Canada." ;
                :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C77812" ;
                rdfs:label "North American" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Novel_Clinical_Phenotype
:Novel_Clinical_Phenotype rdf:type owl:Class ;
                          rdfs:subClassOf :Phenotype ;
                          :Synonyms "Novel Clinical Phenotype" ;
                          :definition "In this retrospective analysis of data sets from patients with sepsis, 4 novel clinical phenotypes were identified that correlated with host-response patterns and clinical outcomes, and simulations suggested these phenotypes may help in understanding heterogeneity of treatment effects." ;
                          :reference "Seymour CW, Kennedy JN, Wang S, Chang CH, Elliott CF, Xu Z, Berry S, Clermont G, Cooper G, Gomez H, Huang DT, Kellum JA, Mi Q, Opal SM, Talisa V, van der Poll T, Visweswaran S, Vodovotz Y, Weiss JC, Yealy DM, Yende S, Angus DC. Derivation, Validation, and Potential Treatment Implications of Novel Clinical Phenotypes for Sepsis. JAMA. 2019 May 28;321(20):2003-2017. doi: 10.1001/jama.2019.5791. PMID: 31104070; PMCID: PMC6537818." ;
                          rdfs:label "Novel Clinical Phenotype" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Nuclear_Receptor
:Nuclear_Receptor rdf:type owl:Class ;
                  rdfs:subClassOf :Receptor ;
                  :Synonyms """Receptor, Nuclear
Nuclear Receptor""" ;
                  :definition "Proteins that regulate transcription via interaction with chromatin and basal transcription machinery at the promoter regions of genes. Nuclear receptors are ligand-dependent transcription factors including steroids, retinoids, vitamin D, unliganded thyroid hormone, and orphan receptors (unknown ligands). Coregulators (coactivators or corepressors) are important in mediating these interactions and thereby modulate positive or negative receptor activity." ;
                  :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17671" ;
                  rdfs:label "Nuclear Receptor" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Nuclear_Receptor_Gene
:Nuclear_Receptor_Gene rdf:type owl:Class ;
                       rdfs:subClassOf :Receptor_Gene ,
                                       :Transcription_Regulation_Gene ;
                       :Synonyms "Nuclear Receptor Gene" ;
                       :definition "Nuclear Receptor Genes (NR Superfamily) encode over 300 ligand-dependent Nuclear Receptor (NRs) transcription factors: steroid, retinoid, vitamin D, TH, and orphan receptors (unknown ligands). Transducing hormone signals into gene transcription, NRs regulate development, pattern formation, cell proliferation, cell differentiation, and homeostasis in target tissues. NRs share a common organization: an (N) modulatory domain, a conserved central Cys-rich region of two C4 zinc fingers that bind to specific upstream ligand-responsive target DNA elements, and a (C) ligand-binding domain. Stabilizing hydrophobic zinc finger interactions contribute to DNA binding specificity, homodimerization, and interaction with other proteins. Ligand-bound NR conformation allows coactivator interaction with the hormone-binding domain that mediates interaction with heat shock proteins, cyclophilins, and hormone." ;
                       :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20709" ;
                       rdfs:label "Nuclear Receptor Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Nuclear_Receptor_Interacting_Protein_3
:Nuclear_Receptor_Interacting_Protein_3 rdf:type owl:Class ;
                                        rdfs:subClassOf :Neonatal_Sepsis_Biomarker ,
                                                        :Regulatory_Protein .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Nucleoside_Reverse_Transcriptase_Inhibitor
:Nucleoside_Reverse_Transcriptase_Inhibitor rdf:type owl:Class ;
                                            rdfs:subClassOf :Reverse_Transcriptase_Inhibitor ;
                                            :Synonyms """Nucleoside Analog Reverse Transcriptase Inhibitor
Nucleoside Reverse Transcriptase Inhibitor
NRTI""" ;
                                            :definition "A substance with a structure similar to a nucleoside molecule that is capable of occupying the active catalytic site of a reverse transcriptase resulting in inhibition of enzyme function, chain termination, and inhibition of viral replication. These compounds are converted to their active phosphorylated forms by cellular kinases." ;
                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C97452" ;
                                            rdfs:label "Nucleoside Reverse Transcriptase Inhibitor" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Nucleosomes
:Nucleosomes rdf:type owl:Class ;
             rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ;
             :Synonyms """Nucleosome
Polynucleosome
Dinucleosome
Dinucleosomes
Polynucleosomes""" ;
             :definition "The repeating structural units of chromatin, each consisting of approximately 200 base pairs of DNA wound around a protein core. This core is composed of the histones H2A, H2B, H3, and H4." ;
             :reference "http://purl.bioontology.org/ontology/MESH/D009707" ;
             rdfs:label "Nucleosomes" .


