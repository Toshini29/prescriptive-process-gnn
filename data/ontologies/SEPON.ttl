                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133278> ;
                                                             :Synonyms """Washed Platelets
Platelets, Washed
Platelets Washed""" ;
                                                             :definition "Whole blood derived or apheresis collected platelets washed with normal saline or saline-buffered with acid citrate dextrose formula-A (ACD-A) or citrate using manual or automated methods. The washed platelets are stored at 20-24 degrees C for up to 4 hours." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133350" ;
                                                             rdfs:label "Washed Platelets" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133351
