                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C139562" ;
                                                             rdfs:label "Upper Abdomen" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C14134
