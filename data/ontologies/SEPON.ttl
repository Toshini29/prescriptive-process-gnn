:Antibiotic_Treatment rdf:type owl:Class ;
                      rdfs:subClassOf :Exogenous_Risk_Factor ;
                      :Synonyms "Antibiotic Treatment" ;
                      :definition "It is a treatment that is used to treat or prevent some types of bacterial infection." ;
                      :reference "http://purl.obolibrary.org/obo/CAROLIO_0003310" ;
                      rdfs:label "Antibiotic Treatment" .


