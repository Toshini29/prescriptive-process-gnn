                                                            :Synonyms """Urethral Gland
Urethra Gland""" ;
                                                            :definition "Any of the glands that secrete mucus into the urethra including the Cowper, Skene, and Littre glands." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12339" ;
                                                            rdfs:label "Urethral Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12346
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12346> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712> ;
                                                            :Synonyms """lacrimal-preorbital gland
glandula lacrimalis
GLAND, LACRIMAL
Lacrimal Gland
Lacrimal gland
lacrimal gland
Lacrimal gland structure (body structure)
LACRIMAL GLAND""" ;
                                                            :definition "Paired, almond-shaped exocrine glands situated superior and posterior to each orbit of the eye that produce and secrete the watery serous component of tears." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12346" ;
                                                            rdfs:label "Lacrimal Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12347
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12347> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C25444> ;
                                                            :Synonyms """Orbital Cavity
BODY CAVITY, ORBITAL
Ocular Orbit
Ocular Orbits
Ocular orbits
Structure of orbit proper (body structure)
Eye Socket
ORBIT
Orbit
Orbit, NOS""" ;
                                                            :definition "The bony cavity of the skull which contains the eye, anterior portion of the optic nerve, ocular muscles and ocular adnexa. Seven bones contribute to the structure of the orbit: the frontal, maxillary, zygomatic, sphenoid, lacrimal, ethmoid, and palatine bones." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12347" ;
                                                            rdfs:label "Orbit" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12367
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12367> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712> ;
                                                            :Synonyms """Mammary Gland
GLAND, MAMMARY
MAMMARY GLAND
mammary gland""" ;
                                                            :definition "In humans, the glands of the breast, consisting of fibrous tissue connecting the lobes and fatty tissue in between the lobes." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12367" ;
                                                            rdfs:label "Mammary Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12376
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12376> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms """BILE DUCT
Bile Duct
DUCT, BILE
bile duct""" ;
                                                            :definition "Any of the ducts conveying bile between the liver and the intestine, including hepatic, cystic, and common bile duct." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12376" ;
                                                            rdfs:label "Bile Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12377
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12377> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Gastrointestinal Tract, Gall Bladder
gallbladder
Gallbladder / Biliar
gall bladder
Gallbladder structure (body structure)
Gallbladder
GALLBLADDER
cholecyst""" ;
                                                            :definition "A pear-shaped organ located under the liver that stores and concentrates bile secreted by the liver. From the gallbladder the bile is delivered through the bile ducts into the intestine thereby aiding the digestion of fat-containing foods." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12377" ;
                                                            rdfs:label "Gallbladder" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12389
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12389> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Esophagus, NOS
Gastrointestinal Tract, Esophagus
Esophageal structure (body structure)
ESOPHAGUS
Esophagus
Oesophagus
esophagus
gullet""" ;
                                                            :definition "The portion of the digestive canal between the pharynx and stomach. It is about 25 cm long and consists of three parts: the cervical part, from the cricoid cartilage to the thoracic inlet; thoracic part, from thoracic inlet to the diaphragm; and abdominal part, below the diaphragm to the cardiac opening of the stomach." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12389" ;
                                                            rdfs:label "Esophagus" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12391
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12391> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Gastrointestinal Tract, Stomach
Stomach, NOS
Stomach structure (body structure)
Gastric
STOMACH
Stomach
stomach""" ;
                                                            :definition "The primary organ of food digestion. It is located under the diaphragm, between the liver and the spleen as well as between the esophagus and the small intestine." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12391" ;
                                                            rdfs:label "Stomach" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12392
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12392> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Gastrointestinal Tract, Liver
Hepatic Body System
Liver structure (body structure)
Hepatic Organ System
Organ System, Hepatic
Body System, Hepatic
LIVER
Liver
liver""" ;
                                                            :definition "A triangular-shaped organ located under the diaphragm in the right hypochondrium. It is the largest internal organ of the body, weighting up to 2 kg. Metabolism and bile secretion are its main functions. It is composed of cells which have the ability to regenerate." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12392" ;
                                                            rdfs:label "Liver" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12393
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12393> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """Pancreas, NOS
Pancreatic structure (body structure)
Gastrointestinal Tract, Pancreas
PANCREAS
Pancreas
pancreas""" ;
                                                            :definition "An organ behind the lower part of the stomach that is the shape of a fish and about the size of a hand. It is a compound gland composed of both exocrine and endocrine tissues. The endocrine pancreas makes insulin so that the body can use glucose (sugar) for energy. The exocrine pancreas makes enzymes that help the body digest food. Spread all over the pancreas are areas called the Islets of Langerhans. The cells in these areas each have a special purpose. The alpha cells make glucagon, which raises the level of glucose in the blood; the beta cells make insulin; the delta cells make somatostatin. There are also PP cells and D1 cells, about which little is known." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12393" ;
                                                            rdfs:label "Pancreas" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12394
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12394> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33224> ;
                                                            :Synonyms """Ear structure (body structure)
EAR
Ear
ear""" ;
                                                            :definition "A sense organ needed for the detection of sound and for establishing balance. The outer ear consists of the auricle, the ear canal as well as the tympanic membrane. The middle ear is made up of an air-filled cavity behind the tympanic membrane that contains the ossicles (malleus, incus and stapes). The inner ear is made up of the cochlea needed for hearing and the vestibular apparatus required for balance." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12394" ;
                                                            rdfs:label "Ear" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12398
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12398> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12704> ;
                                                            :Synonyms """Pineal Gland
GLAND, PINEAL
Pineal Body
Pineal gland
PINEAL GLAND
pineal organ
pineal body
Pineal structure (body structure)
corpus pineale
pineal gland
glandula pinealis
Pineal""" ;
                                                            :definition "A small endocrine gland in the brain, situated beneath the back part of the corpus callosum, that secretes melatonin." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12398" ;
                                                            rdfs:label "Pineal Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12399
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12399> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12704> ;
                                                            :Synonyms """Pituitary structure (body structure)
glandula pituitaria
Nervous System, Pituitary
Pituitary gland
PITUITARY GLAND
Hypophysis Cerebri
Pituitary Gland
GLAND, PITUITARY
pituitary body
pituitary gland
Hypophysis
Pituitary
pituitary""" ;
                                                            :definition "Pea-sized endocrine gland located at the base of the brain in the pituitary fossa. It produces and secretes hormones such as oxytocin and vasopressin, to regulate the activities of the hypothalamus." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12399" ;
                                                            rdfs:label "Pituitary Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12400
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12400> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12704> ;
                                                            :Synonyms """Thyroid structure (body structure)
THYROID GLAND
Thyroid gland
thyroid gland
GLAND, THYROID
Head and Neck, Thyroid
Total Thyroid
Thyroid Gland
Thyroid
thyroid""" ;
                                                            :definition "An endocrine gland located at the base of the neck that produces and secretes thyroxine and other hormones. Thyroxine is important for metabolic control." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12400" ;
                                                            rdfs:label "Thyroid Gland" .


