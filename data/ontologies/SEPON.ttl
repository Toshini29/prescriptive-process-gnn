                                                             rdfs:label "Submandibular Lymph Node Group (Sublevel IB)" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13251
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13251> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13298> ;
