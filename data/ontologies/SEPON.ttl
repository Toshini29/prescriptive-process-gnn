                                      rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13303> ;
                                      :Synonyms """Post-Translational Protein Modification Site
Posttranslational Protein Modification Site
STRUCTURAL ATTACHMENT POINT
Post-Translational Modification Site
Posttranslational Modification Site""" ;
                                      :definition "A post-translational modification site refers to amino acid residues within a peptide that act as acceptors for any modifications that do not happen concurrent with translation." ;
                                      :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C14050" ;
                                      rdfs:label "Post-Translational Modification Site" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Potassium-Sparing_Diuretic
:Potassium-Sparing_Diuretic rdf:type owl:Class ;
                            rdfs:subClassOf :Diuretic ;
                            :Synonyms "Potassium-Sparing Diuretic" ;
                            :definition "Any diuretic agent that produces diuresis without increasing potassium excretion. Potassium sparing diuretics are generally either aldosterone antagonists and thus prevent the aldosterone-mediated promotion of sodium and water retention, or are epithelial sodium channel blockers and prevent the exchange of potassium for sodium in the distal convoluted tubule. These agents cause diuresis without increasing potassium secretion and thus do not cause hypokalemia." ;
                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C49186" ;
                            rdfs:label "Potassium-Sparing Diuretic" .


