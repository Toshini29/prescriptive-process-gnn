:Hyaluronan_Synthases rdf:type owl:Class ;
                      rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ;
                      :Synonyms """Synthase 3, Hyaluronan
Synthetase, Hyaluronic Acid
