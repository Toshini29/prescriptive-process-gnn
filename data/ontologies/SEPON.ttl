:Eskimo rdf:type owl:Class ;
        rdfs:subClassOf :Race ;
        :Synonyms """Eskimo
Inuit""" ;
        :definition "The native people inhabiting the Arctic of northern Canada, Greenland, Alaska, or eastern Siberia. The two main groups referred to as Eskimo are the Yupik and Inuit. A third group, the Aleut, is related. In Canada and Greenland, the term Eskimo has fallen out of favor, as it is considered pejorative by the natives and has been replaced by the term Inuit." ;
        :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C43390" ;
        rdfs:label "Eskimo" .


