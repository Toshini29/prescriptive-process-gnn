           rdfs:subClassOf :Environmental_Etiology ;
           :Synonyms """Infection, NOS
Infection""" ;
           :definition "The invasion of an organism's body tissues by disease-causing agents and their multiplication, as well as the reaction by the host to these organisms and/or toxins that the organisms produce." ;
           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C128320" ;
