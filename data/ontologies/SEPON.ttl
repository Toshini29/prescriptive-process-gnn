                  rdfs:subClassOf :Biochemical_Process ,
                                  :Pharmacotherapy ;
                  :Synonyms """drug interaction
INTERACTION
Drug Interaction""" ;
                  :definition "Alteration of the disposition and/or effect of a drug, owing to the presence of another factor such as a second drug, or food." ;
                  :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C54708" ;
                  rdfs:label "Drug Interaction" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Drug_Use_History
:Drug_Use_History rdf:type owl:Class ;
                  rdfs:subClassOf :Personal_Medical_History ;
                  :Synonyms "Drug Use History" ;
                  :definition "A description of an individual's current and past use and/or abuse of drugs and chemicals. This includes prescription medication, illicit drugs and recreational substances." ;
                  :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C81246" ;
                  rdfs:label "Drug Use History" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Duct_Salivary_Gland_System
:Duct_Salivary_Gland_System rdf:type owl:Class ;
                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33509> ;
                            :Synonyms "Duct Salivary Gland System" ;
                            :definition "The portion of the salivary system that conveys the saliva produced in the acinar salivary gland system to the oral cavity. The duct salivary gland system includes the ductus parotideus, ductus submandibularis, ductus sublingualis major, and ductus sublinguales minores, as well as the ducts from the minor salivary glands." ;
                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32486" ;
                            rdfs:label "Duct Salivary Gland System" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Dysphagia
:Dysphagia rdf:type owl:Class ;
           rdfs:subClassOf :Digestive_System_Signs_and_Symptoms ;
           :Synonyms """Difficulty swallowing
Dysphagia/ Odynophagia
Difficulty Swallowing
Dysphagia
dysphagia""" ;
           :definition "A symptom referring to difficulty in swallowing. It may be observed in patients with stroke, motor neuron disorders, cancer of the throat or mouth, head and neck injuries, Parkinson disease, and multiple sclerosis." ;
           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C2980" ;
           rdfs:label "Dysphagia" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Dyspnea
:Dyspnea rdf:type owl:Class ;
         rdfs:subClassOf :Respiratory_System_Signs_and_Symptoms ;
         :Synonyms """Shortness of breath
Shortness of Breath
Presence and severity of dyspnea
DYSPNEA
Dyspnea
dyspnea""" ;
         :definition "An uncomfortable sensation of difficulty breathing. It may present as an acute or chronic sign of an underlying respiratory or heart disorder." ;
         :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C2998" ;
         rdfs:label "Dyspnea" .


