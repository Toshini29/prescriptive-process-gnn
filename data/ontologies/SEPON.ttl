###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Endotoxin
:Endotoxin rdf:type owl:Class ;
           rdfs:subClassOf :Paediatric_Sepsis_Diagnostic_Biomarker ;
           :Synonyms """Bacterial Pyrogen
Endotoxin
Endotoxins""" ;
           :definition "The lipopolysaccharide complexes that are part of the outer membrane of the cell wall of Gram-negative bacteria such as E. coli, Salmonella, Shigella, Pseudomonas, Neisseria, Haemophilus, and other leading pathogens. Upon bacterial infections, the lipid component (Lipid A) of endotoxin contributes to its toxicity, while the polysaccharide components contribute to immunogenicity." ;
           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C50918" ;
           rdfs:label "Endotoxin" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Endotracheal_Intubation
:Endotracheal_Intubation rdf:type owl:Class ;
                         rdfs:subClassOf :Respiratory_Therapy ;
                         :Synonyms "Endotracheal Intubation" ;
                         :definition "A medical intervention that creates a passage of a tube through the nose or mouth into the trachea for maintenance of the airway, as during the administration of anesthesia." ;
                         :reference "http://purl.obolibrary.org/obo/OAE_0001324" ;
                         rdfs:label "Endotracheal Intubation" .


