                          rdfs:domain :Phenotype ,
                                      :Subtype ;
                          rdfs:range :Prognostic_Biomarker ;
                          :Synonyms "Has_Prognostic_Biomarker" ;
                          rdfs:label "Has_Prognostic_Biomarker" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Has_Surgery
:Has_Surgery rdf:type owl:ObjectProperty ;
             rdfs:domain :Phenotype ,
                         :Subtype ;
             rdfs:range :Surgery ;
             :Synonyms "Has_Surgery" ;
             rdfs:label "Has_Surgery" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Has_Symptom
:Has_Symptom rdf:type owl:ObjectProperty ;
             rdfs:domain :Phenotype ,
                         :Subtype ;
             rdfs:range :Sign_or_Symptom ;
             :Synonyms "Has_Symptom" ;
             rdfs:label "Has_Symptom" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Is_Part_Of
:Is_Part_Of rdf:type owl:ObjectProperty ;
            rdfs:domain :Phenotype ,
                        :Subtype ;
            rdfs:range <http://purl.bioontology.org/ontology/ICD9CM/995.91> ;
            :Synonyms "Is_Part_Of" ;
            rdfs:label "Is_Part_Of" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Protein_Protein_Interaction
:Protein_Protein_Interaction rdf:type owl:ObjectProperty ;
                             rdfs:domain :Protein ,
                                         :Protein_or_Riboprotein_Complex ;
                             rdfs:range :Protein ,
                                        :Protein_or_Riboprotein_Complex ;
                             :Synonyms """Protein_Protein_Interaction
PPI""" ;
                             rdfs:label "Protein_Protein_Interaction" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Related_Gene_Is
:Related_Gene_Is rdf:type owl:ObjectProperty ;
                 rdfs:domain <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C26548> ;
                 rdfs:range <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16612> ;
                 :Synonyms "Related_Gene_Is" ;
                 rdfs:label "Related_Gene_Is" .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#drug_name
:drug_name rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain :Pharmacologic_Substance ;
           rdfs:range xsd:string .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#has_age
:has_age rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty ;
         rdfs:domain <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C25150> ;
         rdfs:range xsd:long .


