:Tetracycline_Antibiotic rdf:type owl:Class ;
                         rdfs:subClassOf :Antibiotic ;
                         :Synonyms """Tetracycline Antibiotic
Tetracycline Antibiotics
Tetracyclines""" ;
                         :definition "Any of a group of broad spectrum naphthacene antibiotics isolated from various species of Streptomyces or produced semisynthetically. In bacteria, tetracycline antibiotics block binding of aminoacyl-tRNA to the mRNA-ribosome complex, thereby inhibiting protein synthesis." ;
                         :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C1595" ;
                         rdfs:label "Tetracycline Antibiotic" .


