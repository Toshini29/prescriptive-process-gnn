###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Infection_Control
:Infection_Control rdf:type owl:Class ;
                   rdfs:subClassOf :Public_Health_Practice ;
                   :Synonyms "Control, Infection" ;
                   :definition "Programs of disease surveillance, generally within health care facilities, designed to investigate, prevent, and control the spread of infections and their causative microorganisms." ;
                   :reference "http://purl.bioontology.org/ontology/MESH/D017053" ;
                   rdfs:label "Infection Control" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Inflammation
:Inflammation rdf:type owl:Class ;
              rdfs:subClassOf :Pathophysiological_Etiology ,
                              :Risk_Factor ;
              :Synonyms """Inflammation
inflammation
INFLAMMATION
Inflammatory Finding""" ;
              :definition "A finding of a localized protective response resulting from injury or destruction of tissues. Inflammation serves to destroy, dilute, or wall off both the injurious agent and the injured tissue. In the acute phase, inflammation is characterized by the signs of pain, heat, redness, swelling, and loss of function. Histologically, inflammation involves a complex series of events, including dilatation of arterioles, capillaries, and venules, with increased permeability and blood flow; exudation of fluids, including plasma proteins; and leukocyte migration into the site of inflammation." ;
              :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C3137" ;
              rdfs:label "Inflammation" .


