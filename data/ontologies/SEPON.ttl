###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cell_Cycle_Gene
:Cell_Cycle_Gene rdf:type owl:Class ;
                 rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16612> ;
                 :Synonyms "Cell Cycle Gene" ;
                 :definition "Cell Cycle Genes encode Cell Cycle Proteins, which control the cell division cycle. This family of proteins, classified on the basis of related function, includes a wide variety of classes, including cyclin-dependent kinases, mitogen-activated kinases, cyclins, and phosphoprotein phosphatases, as well as their putative substrates, such as chromatin-associated proteins, cytoskeletal proteins, and transcription factors." ;
                 :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C20917" ;
                 rdfs:label "Cell Cycle Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cell_Cycle_Protein
:Cell_Cycle_Protein rdf:type owl:Class ;
                    rdfs:subClassOf :Regulatory_Protein ;
                    :Synonyms "Cell Cycle Protein" ;
                    :definition "Proteins involved in the process of cell division. Numerous proteins of different functionality and type are involved in this process." ;
                    :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17761" ;
                    rdfs:label "Cell Cycle Protein" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Cephalosporin_Antibiotic
:Cephalosporin_Antibiotic rdf:type owl:Class ;
                          rdfs:subClassOf :Beta-Lactam_Antibiotic ;
                          :Synonyms """Cephalosporin Antibiotic
cephalosporin
Cephalosporins""" ;
                          :definition "A synthetic or semi-synthetic beta-lactam antibiotic derived from Acremonium (Cephalosporium) fungi with bactericidal activity. Cephalosporin antibiotics bind to and inactivate penicillin-binding proteins (PBPs) located on the inner membrane of the bacterial cell wall. Inactivation of PBPs interferes with the cross-linkage of peptidoglycan chains necessary for bacterial cell wall strength and rigidity. This interrupts bacterial cell wall synthesis and results in the weakening of the bacterial cell wall, eventually causing cell lysis." ;
                          :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C357" ;
                          rdfs:label "Cephalosporin Antibiotic" .


