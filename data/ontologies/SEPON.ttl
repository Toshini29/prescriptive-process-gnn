                                                             :Synonyms """Rejuvenated Red Blood Cells
Red Blood Cells, Rejuvenated
Red Blood Cells Rejuvenated""" ;
                                                             :definition "Red blood cells treated to restore cell integrity with a rejuvenating solution, such as pyruvate inosine." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133356" ;
                                                             rdfs:label "Rejuvenated Red Blood Cells" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133357
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133357> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133280> ;
                                                             :Synonyms """Washed Red Blood Cells
Red Blood Cells, Washed
Red Blood Cells Washed""" ;
                                                             :definition "Red blood cells typically washed using normal saline with or without small amounts of dextrose using manual or automated methods. The washed red blood cells are stored at 1-6 degrees C for up to 24 hours." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133357" ;
                                                             rdfs:label "Washed Red Blood Cells" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13337
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13337> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13049> ;
                                                            :Synonyms "Germinal Center" ;
                                                            :definition "Sites in secondary lymphoid tissue where follicular dendritic cells present antigens to B-cells and follicular helper T-cells." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13337" ;
                                                            rdfs:label "Germinal Center" .


