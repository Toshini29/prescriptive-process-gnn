                                                            :Synonyms """PLEURAL CAVITY
BODY CAVITY, PLEURAL
Pleural Cavity
pleural cavity
Pleural Space""" ;
                                                            :definition "The potential space between parietal and visceral pleurae. There is a separate pleural cavity for each lung." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12840" ;
                                                            rdfs:label "Pleural Cavity" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12841
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12841> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12919> ;
                                                            :Synonyms """Reproductive Tract
Genital tract
reproductive system
Reproductive System
Reproductive Body System
Reproductive Organ System""" ;
