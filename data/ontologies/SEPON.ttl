###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Immature_Granulocyte
:Immature_Granulocyte rdf:type owl:Class ;
                      rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ;
                      :Synonyms "Immature Granulocyte" ;
                      :definition "A not-yet-mature white blood cell with staining granules in its cytoplasm. The staining granules may be neutrophilic, acidophilic, or basophilic in character. There are indications that an immature granulocyte count is a better measure of infection and sepsis than a total white blood cell count and comparable to absolute neutrophil count." ;
                      :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13113" ;
                      rdfs:label "Immature Granulocyte" .


