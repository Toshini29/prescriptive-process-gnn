                                                            :Synonyms """MUSCULOSKELETAL SYSTEM
Musculoskeletal System
Musculoskeletal""" ;
                                                            :definition "The system of muscles, tendons, ligaments, bones, joints and associated tissues that move the body and maintain its form." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12754" ;
                                                            rdfs:label "Musculoskeletal System" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12755
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12755> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12919> ;
