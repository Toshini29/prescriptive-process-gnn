###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Guanine_Nucleotide_Exchange_Factor
:Guanine_Nucleotide_Exchange_Factor rdf:type owl:Class ;
                                    rdfs:subClassOf :Signaling_Pathway_Protein ;
                                    :Synonyms """Guanine Nucleotide-Exchange Factor
Guanine Nucleotide Exchange Factor
Guanyl-Nucleotide Exchange Factor
Guanyl-Nucleotide Releasing Factor
Guanine Nucleotide-Releasing Factor
GDP Exchange Factors
GDP-GTP Exchange Factors
GEF""" ;
                                    :definition "Proteins that catalyze the release and exchange of GDP for GTP from GTP-binding regulatory proteins, which are active in the GTP-bound form." ;
                                    :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C17494" ;
                                    rdfs:label "Guanine Nucleotide Exchange Factor" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Gut-Associated_Lymphoid_Tissue
:Gut-Associated_Lymphoid_Tissue rdf:type owl:Class ;
                                rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12910> ;
                                :Synonyms """GUT-ASSOCIATED LYMPHOID TISSUE
Gut-Associated Lymphoid Tissue
Gut Associated Lymphoid Tissue
GALT""" ;
                                :definition "Non-encapsulated accumulations of lymphoid tissue in the alimentary tract that form a secretory immune system containing cells committed to IgA or IgE synthesis; It includes Peyer's patches and the lymphoid tissue which is present throughout the gastrointestinal mucosa." ;
                                :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12936" ;
                                rdfs:label "Gut-Associated Lymphoid Tissue" .


