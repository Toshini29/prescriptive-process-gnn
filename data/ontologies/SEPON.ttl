                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133340" ;
                                                             rdfs:label "Ocular Tissue" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133342
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133342> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133266> ;
                                                             :Synonyms "PF24 Plasma" ;
                                                             :definition "The fluid portion of one unit of human blood intended for transfusion which has been separated from whole blood and placed at -18 degrees C or colder within 24 hours from whole blood collection. When prepared by automated apheresis the product is stored at 1 degree to 6 degrees C within 8 hours of collection and frozen at -18 degrees C or colder within 24 hours of collection." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133342" ;
                                                             rdfs:label "PF24 Plasma" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133343
