                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12401" ;
                                                            rdfs:label "Eye" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12403
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12403> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13018> ;
                                                            :Synonyms """mammalian oviduct
uterine tube
FALLOPIAN TUBE
Fallopian tube
Fallopian Tube, NOS
fallopian tube
Fallopian Tube
Fallopian Tubes
OVIDUCT
Oviduct""" ;
                                                            :definition "One of a pair of tubes that extend from the uterus to each of the ovaries. Following ovulation the egg travels down the fallopian tube to the uterus where fertilization may or may not occur." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12403" ;
                                                            rdfs:label "Fallopian Tube" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12404
