                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C14134> ;
                                                            :Synonyms "Helix" ;
                                                            :definition "A structure consisting of something wound in a continuous series of loops." ;
