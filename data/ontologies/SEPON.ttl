:Employed rdf:type owl:Class ;
          rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C179143> ;
          :Synonyms """Employed
Employment""" ;
          :definition "The state of being engaged in an activity or service for wages or salary." ;
          :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C25172" ;
          rdfs:label "Employed" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Emtricitabine
:Emtricitabine rdf:type owl:Class ;
               rdfs:subClassOf :Nucleoside_Reverse_Transcriptase_Inhibitor ;
               :Synonyms """2(1H)-Pyrimidinone,4-amino-5-fluoro-1-(2-(hydroxymethyl)-1,3-oxathiolan-5-yl)-,(2R-cis)-Emtricitabine
EMTRICITABINE
(-)-2'-Deoxy-5-fluoro-3'-thiacytidine
BW-524W91
Coviracil
Emtriva
FTC
dOTFC""" ;
               :definition "A synthetic fluoro derivative of thiacytidine with potent antiviral activity. Emtricitabine is phosphorylated to form emtricitabine 5'-triphosphate within the cell. This metabolite inhibits the activity of human immunodeficiency virus (HIV) reverse transcriptase both by competing with the natural substrate deoxycytidine 5'-triphosphate and by incorporation into viral DNA causing a termination of DNA chain elongation (due to the lack of the essential 3'-OH group)." ;
               :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C47509" ;
               rdfs:label "Emtricitabine" .


