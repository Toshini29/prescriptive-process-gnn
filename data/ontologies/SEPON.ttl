:Therapy rdf:type owl:Class ;
         rdfs:subClassOf :Therapeutic_Procedure ;
         :Synonyms "treatment" ;
         :definition "Used with diseases for therapeutic interventions except drug therapy, diet therapy, radiotherapy, and surgery, for which specific subheadings exist. The concept is also used for articles and books dealing with multiple therapies." ;
         :reference "http://purl.bioontology.org/ontology/MESH/Q000628" ;
         rdfs:label "Therapy" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Thiazide_Diuretic
:Thiazide_Diuretic rdf:type owl:Class ;
                   rdfs:subClassOf :Diuretic ;
                   :Synonyms "Thiazide Diuretic" ;
                   :definition "Any benzothiadiazide derivative or other thiazide-like agent with diuretic and anti-hypertensive activity. Thiazide diuretics inhibit the sodium-chloride transporter in the distal tubule in the kidneys, thereby suppressing sodium and chloride reabsorption from the distal convoluted tubules (DCT) and increasing the excretion of sodium, chloride, potassium and water. In addition, thiazide diuretics decrease excretion of calcium and uric acid. These agents cause vasodilation possibly by activating calcium-activated potassium channels in vascular smooth muscle and inhibiting various carbonic anhydrases in vascular tissue." ;
                   :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C49185" ;
                   rdfs:label "Thiazide Diuretic" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Thiobarbituric_Acid_Reactive_Substances
:Thiobarbituric_Acid_Reactive_Substances rdf:type owl:Class ;
                                         rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ,
                                                         :Neonatal_Sepsis_Biomarker ;
                                         :Synonyms "TBARs" ;
                                         :definition "Low-molecular-weight end products, probably malondialdehyde, that are formed during the decomposition of lipid peroxidation products. These compounds react with thiobarbituric acid to form a fluorescent red adduct." ;
                                         :reference "http://purl.bioontology.org/ontology/MESH/D017392" ;
                                         rdfs:label "Thiobarbituric Acid Reactive Substances" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Thrombin_Time
:Thrombin_Time rdf:type owl:Class ;
               rdfs:subClassOf :Coagulation_Study ;
               :Synonyms """Thrombin Clotting Time
Thrombin Time
TCT
TT""" ;
               :definition "A measurement of the time it takes a plasma sample to clot after adding the active enzyme thrombin." ;
               :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C80365" ;
               rdfs:label "Thrombin Time" .


