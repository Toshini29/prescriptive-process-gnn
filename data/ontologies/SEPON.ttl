                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C32589> ;
                                                             :Synonyms """Cervicovaginal Secretion
CERVICOVAGINAL SECRETION""" ;
                                                             :definition "The watery fluid, consisting of vulvar gland, endometrium, and oviduct secretions, cervical mucus, vaginal wall plasma transudate, exfoliated cells, and bacterial and immune cell products, that hydrates and forms an antimicrobial barrier for the mucosa of the lower female genital tract." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C150892" ;
                                                             rdfs:label "Cervicovaginal Secretion" .


