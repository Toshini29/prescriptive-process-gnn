                                                             rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133280> ;
                                                             :Synonyms """Red Blood Cells Frozen
Red Blood Cells, Frozen
Frozen Red Blood Cells""" ;
                                                             :definition "Red blood cells stored at an ultra-low temperature in the presence of a cryoprotective agent. These may be preserved for long periods of time." ;
                                                             :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C133352" ;
                                                             rdfs:label "Frozen Red Blood Cells" .


