:Syndrome rdf:type owl:Class ;
          rdfs:subClassOf :Inflammation ;
          :Synonyms """Syndrome
syndrome""" ;
          :definition "A group of signs, symptoms, and clinicopathological characteristics that may or may not have a genetic basis and collectively define an abnormal condition." ;
          :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C28193" ;
          rdfs:label "Syndrome" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Systemic_Immune-inflammation_Index
:Systemic_Immune-inflammation_Index rdf:type owl:Class ;
                                    rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ,
                                                    :Clinical_Assessment_Indicator ,
                                                    :Neonatal_Sepsis_Biomarker ;
                                    :Synonyms """Systemic Immune-inflammation Index
SII""" ;
                                    :definition "SII is an inflammation-related indicator that integrates neutrophil, platelet, and lymphocyte counts and can reflect the comprehensive immune and inflammation situation in the body.[url:https://pubmed.ncbi.nlm.nih.gov/31849367/] The SII was defined as follows: SII = P × N/L, where P, N, and L were the preoperative peripheral platelet, neutrophil, and lymphocyte counts, respectively. [url:https://pubmed.ncbi.nlm.nih.gov/25271081/]" ;
                                    :reference "http://www.semanticweb.org/admin/ontologies/2022/7/MIO:02388" ;
                                    rdfs:label "Systemic Immune-inflammation Index" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Systemic_Inflammatory_Response_Syndrome
:Systemic_Inflammatory_Response_Syndrome rdf:type owl:Class ;
                                         rdfs:subClassOf :Syndrome ;
                                         :Synonyms """systemic inflammatory response syndrome
Systemic Inflammatory Response Syndrome
SIRS""" ;
                                         :definition "A generalized state of dysregulated inflammation induced by noninfectious processes. It is characterized by two or more of the following signs and symptoms: fever or hypothermia, increased heart rate, increased respiratory rate, and abnormal white blood cell count." ;
                                         :reference "Singer M, Deutschman CS, Seymour CW, Shankar-Hari M, Annane D, Bauer M, Bellomo R, Bernard GR, Chiche JD, Coopersmith CM, Hotchkiss RS, Levy MM, Marshall JC, Martin GS, Opal SM, Rubenfeld GD, van der Poll T, Vincent JL, Angus DC. The Third International Consensus Definitions for Sepsis and Septic Shock (Sepsis-3). JAMA. 2016 Feb 23;315(8):801-10. doi: 10.1001/jama.2016.0287. PMID: 26903338; PMCID: PMC4968574." ,
                                                    "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C94832" ;
                                         rdfs:label "Systemic Inflammatory Response Syndrome" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Systolic_Blood_Pressure
