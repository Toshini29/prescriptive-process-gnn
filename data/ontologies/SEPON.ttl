###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Maximum_Aggregation_Rate
:Maximum_Aggregation_Rate rdf:type owl:Class ;
                          rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ;
                          :Synonyms """Maximum Aggregation Rate
MAR""" ;
                          :definition "The maximum platelet aggregation rate refers to the aggregation ability of platelets in the bloodstream, and is an indicator in platelet aggregation function testing. This value is usually divided by the maximum number of platelets divided by the diameter of platelets." ;
                          rdfs:label "Maximum Aggregation Rate" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Mean_Arterial_Pressure
:Mean_Arterial_Pressure rdf:type owl:Class ;
                        rdfs:subClassOf :Adult_Sepsis_Prognostic_Biomarker ,
                                        :Blood_Pressure ;
                        :Synonyms """Mean Arterial Pressure
MAP""" ;
                        :definition "The mean pressure of the blood within the arterial circulation. The arterial pressure may be directly measured by insertion of an intra-arterial catheter connected to a transducer. The mean arterial pressure (MAP) can be calculated by subsequent analysis of the waveform. MAP can be approximated without an invasive procedure using the following formula: diastolic pressure plus 1/3 of the pulse pressure, where pulse pressure is systolic pressure - diastolic pressure." ;
                        :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C49679" ;
                        rdfs:label "Mean Arterial Pressure" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Mean_Neutrophil_Volume
:Mean_Neutrophil_Volume rdf:type owl:Class ;
                        rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ;
                        :Synonyms """Mean Neutrophil Volume
MNV""" ;
                        :definition "The average size of the neutrophils present in a blood sample." ;
                        :reference "Lee AJ, Kim SG. Mean cell volumes of neutrophils and monocytes are promising markers of sepsis in elderly patients. Blood Res. 2013 Sep;48(3):193-7. doi: 10.5045/br.2013.48.3.193. Epub 2013 Sep 25. PMID: 24086939; PMCID: PMC3786279." ;
                        rdfs:label "Mean Neutrophil Volume" .


