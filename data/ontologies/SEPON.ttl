:Anti-Infective_Agent rdf:type owl:Class ;
                      rdfs:subClassOf :Pharmacologic_Substance ;
                      :Synonyms """Anti-Infective Agent
Anti-Infective Agents
AntiInfectives
AntiInfective Drugs
Anti-Infective Drugs
Anti-Infectives
AntiInfective Agents""" ;
                      :definition "A pharmacological agent that can kill or prevent the reproduction of infectious organisms." ;
                      :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C254" ;
                      rdfs:label "Anti-Infective Agent" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Antibiotic
:Antibiotic rdf:type owl:Class ;
            rdfs:subClassOf :Anti-Infective_Agent ;
            :Synonyms """Antimicrobial
antimicrobial
Antibiotic Drugs
Antibiotics
Antimicrobial Agent
Antibiotic Therapy
Antibiotic Agents
Antibiotic
antibiotic""" ;
            :definition "Substances naturally produced by microorganisms or their derivatives that selectively target microorganisms not humans. Antibiotics kill or inhibit the growth of microorganisms by targeting components of the microbial cell absent from human cells, including bacterial cell walls, cell membrane, and 30S or 50S ribosomal subunits. These substances are used in the treatment of bacterial and other microbial infections." ;
            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C258" ;
            rdfs:label "Antibiotic" .


