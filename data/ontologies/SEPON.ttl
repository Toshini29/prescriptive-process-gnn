:Peptidase rdf:type owl:Class ;
           rdfs:subClassOf :Hydrolase ;
           :Synonyms """Proteolytic Enzyme
Peptide Hydrolase
Peptidase
Protease
Proteases
Proteinase""" ;
           :definition "Enzymes acting on peptide bonds." ;
           :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16965" ;
           rdfs:label "Peptidase" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Peptidase_Gene
:Peptidase_Gene rdf:type owl:Class ;
                rdfs:subClassOf :Hydrolase_Gene ;
                :Synonyms """Peptidase Gene
Proteinase Gene
Protease Gene""" ;
                :definition "A gene that encodes an enzyme that is capable of hydrolyzing the peptide bonds found between amino acids in proteins." ;
                :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C26003" ;
                rdfs:label "Peptidase Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Peptide_Hormone
:Peptide_Hormone rdf:type owl:Class ;
                 rdfs:subClassOf :Protein ;
                 :Synonyms "Peptide Hormone" ;
                 :definition "Small proteins that function as hormonal signals, synthesized and secreted by one tissue or organ with physiological effects on other tissues or organs." ;
                 :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C1746" ;
                 rdfs:label "Peptide Hormone" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Peptide_Hormone_Gene
:Peptide_Hormone_Gene rdf:type owl:Class ;
                      rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C16612> ;
                      :Synonyms "Peptide Hormone Gene" ;
                      :definition "Peptide Hormone Genes encode Peptide Hormones, typically synthesized as larger precursor molecules from which are derived smaller active proteins that function as hormonal signals secreted by one tissue or organ and have physiological effects on other tissues or organs." ;
                      :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C25994" ;
                      rdfs:label "Peptide Hormone Gene" .


###  http://www.semanticweb.org/zchero/ontologies/2023/11/SepsisOntology#Peptidoglycan
:Peptidoglycan rdf:type owl:Class ;
               rdfs:subClassOf :Adult_Sepsis_Diagnostic_Biomarker ;
               :Synonyms """Pseudomurein
Murein""" ;
               :definition "A structural polymer of the bacterial cell envelope consisting of sugars and amino acids which is responsible for both shape determination and cellular integrity under osmotic stress in virtually all bacteria." ;
               :reference "http://purl.bioontology.org/ontology/MESH/D010457" ;
               rdfs:label "Peptidoglycan" .


