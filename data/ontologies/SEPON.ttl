                                                            :Synonyms """Regulatory Process
Regulation""" ;
                                                            :definition "Aprocess that acts to control the rate or manner in which another process progresses or a product is formed." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C48805" ;
                                                            rdfs:label "Regulatory Process" .


