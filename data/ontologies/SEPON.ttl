                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33773" ;
                                                            rdfs:label "Thymic Trabecula" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33774
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33774> rdf:type owl:Class ;
