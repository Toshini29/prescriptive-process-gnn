###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33635
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33635> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Striated Duct" ;
                                                            :definition "A type of intralobular duct, which is found in some salivary glands, and which is lined by low columnar epithelial cells that have characteristic basal striations, which are formed by regions of basal membrane invaginations with mitochondrial accumulation." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33635" ;
                                                            rdfs:label "Striated Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33649
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33649> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms """Submandibular Duct
Wharton's Duct""" ;
                                                            :definition "A small, tubular passageway that transports saliva from the submandibular gland into the floor of the mouth, exiting adjacent to the lingual frenulum." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33649" ;
                                                            rdfs:label "Submandibular Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33691
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33691> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12765> ;
                                                            :Synonyms "Superior Parathyroid Gland" ;
                                                            :definition "Either of two paired parathyroid glands closest to the head." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33691" ;
                                                            rdfs:label "Superior Parathyroid Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33712
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33712> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12712> ;
                                                            :Synonyms """SUDORIFEROUS GLAND
Sweat Gland""" ;
                                                            :definition "The small coiled tubes in the skin that produce and secrete sweat." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33712" ;
                                                            rdfs:label "Sweat Gland" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33713
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33713> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms "Sweat Gland Duct" ;
                                                            :definition "The small tube that drains sweat from the sweat gland to the skin." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33713" ;
                                                            rdfs:label "Sweat Gland Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33718
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33718> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C13236> ;
                                                            :Synonyms """FLUID, SYNOVIAL
Synovial Fluid
SYNOVIAL FLUID
Fluid, Joint
Fluid, synovial (Joint fluid)
Synovia""" ;
                                                            :definition "A viscid fluid secreted by the synovial membrane, serving as a lubricant." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33718" ;
                                                            rdfs:label "Synovial Fluid" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33739
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33739> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C34062> ;
                                                            :Synonyms """TEAR
Tear""" ;
                                                            :definition "A fluid containing oils, mucin, and proteins, which is secreted by the lacrimal gland and cleans and lubricates the eye." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33739" ;
                                                            rdfs:label "Tear" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33768
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33768> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C12948> ;
                                                            :Synonyms """Thoracic duct structure (body structure)
Thoracic Duct""" ;
                                                            :definition "The largest lymphatic vessel in the body, originating at the cisternal chyli and emptying into the junction of the left internal jugular and subclavian veins. It receives lymph from the entire body, with the exception of the right upper limb, the right side of the head and neck, and the right upper thorax." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33768" ;
                                                            rdfs:label "Thoracic Duct" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33772
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33772> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33952> ;
                                                            :Synonyms "Thymic Lobule" ;
                                                            :definition "A structure in a lobe of the thymus 0.5 -2 mm in diameter. The lobule is divided into an outer cortex and inner medulla. Lobules are separated from each other by connective tissue septa, however, the medullary tissue is continuous from lobule to lobule. Lymphocytes, reticular cells and macrophages are found in the lobules." ;
                                                            :reference "http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33772" ;
                                                            rdfs:label "Thymic Lobule" .


###  http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33773
<http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C33773> rdf:type owl:Class ;
